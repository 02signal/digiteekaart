---
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";
---

<link rel="alternate" type="text/plain" href="/llms.txt" title="Digiteekaart.ee LLM summary" />
<link rel="alternate" type="application/json" href="/site-profile.json" title="Digiteekaart.ee machine-readable profile" />

{gaMeasurementId ? (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
    <script is:inline define:vars={{ gaMeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag("js", new Date());
      gtag("config", gaMeasurementId);
    </script>
  </>
) : null}

<script is:inline>
  (() => {
    const attributionKey = "digiteekaart:attribution";
    const lastCtaKey = "digiteekaart:last_cta";
    const campaignKeys = [
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_term",
      "utm_content",
      "gclid",
      "gbraid",
      "wbraid",
      "msclkid",
      "fbclid",
      "li_fat_id"
    ];

    const safeJsonRead = (key) => {
      try {
        return JSON.parse(sessionStorage.getItem(key) || "{}") || {};
      } catch {
        return {};
      }
    };

    const safeJsonWrite = (key, value) => {
      try {
        sessionStorage.setItem(key, JSON.stringify(value));
      } catch {
        // If storage is unavailable, events still work without attribution context.
      }
    };

    const referrerHost = (referrer) => {
      if (!referrer) return "";
      try {
        return new URL(referrer).hostname;
      } catch {
        return "";
      }
    };

    const captureAttribution = () => {
      const params = new URLSearchParams(window.location.search);
      const current = safeJsonRead(attributionKey);
      const now = new Date().toISOString();

      if (!current.landingPage) {
        current.landingPage = window.location.href;
        current.landingPath = `${window.location.pathname}${window.location.search}`;
        current.firstReferrer = document.referrer || "";
        current.referrerHost = referrerHost(document.referrer);
        current.firstSeenAt = now;
      }

      current.currentPage = window.location.href;
      current.currentPath = `${window.location.pathname}${window.location.search}`;
      current.lastSeenAt = now;

      let hasCampaignValue = false;
      campaignKeys.forEach((key) => {
        const value = params.get(key);
        if (!value) return;
        hasCampaignValue = true;
        current[key] = value;
      });

      if (hasCampaignValue) {
        current.campaignCapturedAt = now;
      }

      safeJsonWrite(attributionKey, current);
      return current;
    };

    const getAttribution = () => captureAttribution();
    const getLastCta = () => safeJsonRead(lastCtaKey);
    const compactAttribution = () => {
      const attribution = getAttribution();
      const lastCta = getLastCta();
      return {
        landing_path: attribution.landingPath || "",
        referrer_host: attribution.referrerHost || "",
        utm_source: attribution.utm_source || "",
        utm_medium: attribution.utm_medium || "",
        utm_campaign: attribution.utm_campaign || "",
        utm_content: attribution.utm_content || "",
        utm_term: attribution.utm_term || "",
        click_id_type: attribution.gclid ? "gclid" : attribution.msclkid ? "msclkid" : attribution.fbclid ? "fbclid" : attribution.li_fat_id ? "li_fat_id" : "",
        last_cta_label: lastCta.cta_label || "",
        last_cta_event: lastCta.event_name || ""
      };
    };

    captureAttribution();

    const track = (eventName, params = {}) => {
      const detail = {
        source_path: window.location.pathname,
        ...compactAttribution(),
        ...params
      };
      if (typeof window.gtag === "function") {
        window.gtag("event", eventName, detail);
      }
      window.dispatchEvent(new CustomEvent("digiteekaart:event", {
        detail: { eventName, params: detail }
      }));
    };

    window.digiteekaartTrack = track;
    window.digiteekaartGetAttribution = getAttribution;
    window.digiteekaartGetLastCta = getLastCta;

    document.addEventListener("click", (event) => {
      const target = event.target instanceof Element
        ? event.target.closest("[data-track-event]")
        : null;
      if (!target) return;
      const eventName = target.getAttribute("data-track-event") || "cta_click";
      const cta = {
        event_name: eventName,
        cta_label: target.getAttribute("data-track-label") || target.textContent?.trim() || "",
        cta_href: target instanceof HTMLAnchorElement ? target.href : "",
        cta_path: target instanceof HTMLAnchorElement ? `${target.pathname}${target.search}${target.hash}` : "",
        clicked_at: new Date().toISOString()
      };
      safeJsonWrite(lastCtaKey, cta);
      track(eventName, {
        cta_label: cta.cta_label,
        cta_href: cta.cta_href,
        page_title: document.title
      });
    });

    const startedForms = new WeakSet();
    const startedTools = new WeakSet();
    document.addEventListener("focusin", (event) => {
      const target = event.target instanceof Element ? event.target : null;
      if (!target) return;

      const toolSection = target.closest("[data-tool-section]");
      if (toolSection && !startedTools.has(toolSection)) {
        startedTools.add(toolSection);
        track("tool_start", {
          tool_name: toolSection.getAttribute("data-tool-section") || "tool",
          source_site: "digiteekaart.ee"
        });
      }

      const form = target.closest("[data-site-lead-form]");
      if (!form || startedForms.has(form)) return;
      // Kui vormil on eraldi kontaktisektsioon, loeb leadi alguseks alles selle puudutamine,
      // mitte toetusfiltri kasutamine.
      const contactSection = form.querySelector("[data-lead-contact-section]");
      if (contactSection && !target.closest("[data-lead-contact-section]")) return;
      startedForms.add(form);
      track("lead_form_start", {
        form_name: "digiteekaart_eelhindamine",
        source_site: form.getAttribute("data-source-site") || "digiteekaart.ee"
      });
    });
  })();
</script>
