---
import Analytics from "../components/Analytics.astro";
import Footer from "../components/Footer.astro";
import { fundingRulesReviewedAt, supportPrograms } from "../data/supportPrograms";
import "../styles/global.css";

const eisRoadmapUrl = "https://eis.ee/teenused/digitaliseerimise-teekaardi-toetus/";
const eisDevelopmentUrl = "https://eis.ee/teenused/digitaliseerimise-teekaardi-arendustegevused-toetus/";
const emailHref = "mailto:info@02signal.ai?subject=Digiteekaart.ee%20-%20EIS%20teekaardi%20eelhindamine";
const leadWebhookUrl = import.meta.env.PUBLIC_SITE_LEAD_WEBHOOK_URL ?? "";
const rikLookupUrl = import.meta.env.PUBLIC_RIK_LOOKUP_URL ?? "https://miwpctshbcmkpwvdokne.supabase.co/functions/v1/rik-company-lookup";
const rikLookupKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "";
const supportProgramJsonUrl = "https://digiteekaart.ee/funding-programs.json";
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://digiteekaart.ee/#organization",
      name: "Digiteekaart.ee",
      legalName: "Ettevõtluskeskus OÜ",
      url: "https://digiteekaart.ee/",
      email: "info@02signal.ai",
      telephone: "+37258180435",
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        telephone: "+37258180435",
        email: "info@02signal.ai",
        areaServed: "EE",
        availableLanguage: ["et"]
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://digiteekaart.ee/#website",
      name: "Digiteekaart.ee",
      url: "https://digiteekaart.ee/",
      publisher: { "@id": "https://digiteekaart.ee/#organization" },
      inLanguage: "et"
    },
    {
      "@type": "Service",
      "@id": "https://digiteekaart.ee/#service",
      name: "Digitaliseerimise teekaardi ettevalmistus ja eelhindamine",
      serviceType: "Digitaliseerimise teekaart, EIS toetuse ettevalmistus, ettevõtte digiplaan",
      provider: { "@id": "https://digiteekaart.ee/#organization" },
      areaServed: "EE",
      audience: {
        "@type": "Audience",
        audienceType: "Eesti väike- ja keskmise ettevõtte omanikud"
      }
    },
    {
      "@type": "Dataset",
      "@id": "https://digiteekaart.ee/funding-programs.json#dataset",
      name: "Digiteekaart.ee toetuste eelhindamise reeglid",
      description: "Masinloetav reeglite register EIS digiteekaardi, RTE tarkvara/liidestuse ja seotud meetmete esmaseks eelhindamiseks.",
      url: supportProgramJsonUrl,
      inLanguage: "et",
      dateModified: fundingRulesReviewedAt,
      creator: { "@id": "https://digiteekaart.ee/#organization" },
      isBasedOn: supportPrograms.map((program) => program.sourceUrl)
    }
  ]
};
---

<!doctype html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Digiteekaart.ee | EIS digitaliseerimise teekaardi eelhindamine</title>
    <meta
      name="description"
      content="Aitame Eesti ettevõtte omanikul aru saada, kas EIS digitaliseerimise teekaardi toetus võiks sobida ja mida teekaart peab sisaldama."
    />
    <link rel="canonical" href="https://digiteekaart.ee/" />
    <meta property="og:title" content="Digiteekaart.ee | Digitaliseerimise teekaardi eelhindamine" />
    <meta
      property="og:description"
      content="Selge esimene kontroll: kas ettevõte võiks EIS digitaliseerimise teekaardi toetuseks sobida ja milline töö on vaja ette valmistada."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://digiteekaart.ee/" />
    <meta property="og:image" content="https://digiteekaart.ee/hero-digiteekaart.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    <Analytics />
  </head>
  <body>
    <header class="topbar">
      <nav class="nav" aria-label="Põhinavigeerimine">
        <a class="brand" href="/">Digiteekaart.ee</a>
        <div class="navlinks">
          <a href="#toetus">Toetus</a>
          <a href="#sobivus">Sobivus</a>
          <a href="#naidis">Näidis</a>
          <a href="/digitaliseerimise-teekaart/">Digiteekaart</a>
          <a href="/musterteekaart/">Musterteekaart</a>
          <a href="/rte-tarkvara-liidestus/">RTE</a>
          <a href="/faq/">FAQ</a>
          <a href="#eelhindamine">Eelhindamine</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-inner">
          <span class="eyebrow">Digitaliseerimise teekaart ettevõtte omanikule</span>
          <h1>Kas EIS-i digiteekaardi toetus võiks teile sobida?</h1>
          <p>
            Enne taotlemist tasub rahulikult üle vaadata: kas ettevõte vastab tingimustele,
            mida teekaart peab sisaldama ja kas sellest oleks päriselt kasu.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="#eelhindamine" data-track-event="cta_click" data-track-label="home_hero_eelhindamine">Tee eelhindamine</a>
            <a class="btn btn-secondary" href="tel:+37258180435" data-track-event="phone_click" data-track-label="home_hero_phone">Helista +372 5818 0435</a>
          </div>
          <div class="proof">
            <div><strong>kuni 10 000 €</strong><span>EIS teekaardi toetus</span></div>
            <div><strong>3 aasta plaan</strong><span>kitsaskohad, prioriteedid, maksumus</span></div>
            <div><strong>järgmine samm</strong><span>arendustegevuste toetus võib järgneda</span></div>
          </div>
        </div>
      </section>

      <section id="toetus" class="white">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">EIS meede lihtsas keeles</span>
            <h2>Digiteekaart ei ole lihtsalt dokument. See on otsuse alus: mida teha, miks teha ja mis see maksab.</h2>
            <p>
              EIS-i avaliku info järgi on digitaliseerimise teekaardi toetuse eesmärk aidata ettevõttel
              koostada 3 aasta vaade digitaliseerimise kitsaskohtadele, prioriteetidele, maksumusele,
              tasuvusele ja mõjule. Enne tööd kontrollime alati kehtivad tingimused EIS-i lehelt üle.
            </p>
          </div>
          <div class="grid-3">
            <article class="card">
              <span class="stat">10 000 €</span>
              <h3>Teekaardi toetus</h3>
              <p>EIS-i lehel on välja toodud toetuse suurimaks summaks kuni 10 000 eurot.</p>
            </article>
            <article class="card">
              <span class="stat">30-50%</span>
              <h3>Omafinantseering</h3>
              <p>Oma panus sõltub ettevõttest ja tingimustest. Kontrollime selle enne pakkumist üle.</p>
            </article>
            <article class="card">
              <span class="stat">200 000 €</span>
              <h3>Müügitulu piir</h3>
              <p>EIS-i info järgi peab kahe eelmise majandusaasta keskmine põhitegevusala müügitulu olema vähemalt 200 000 eurot.</p>
            </article>
          </div>
          <p class="notice">
            Ametlik info: <a href={eisRoadmapUrl}>EIS digitaliseerimise teekaardi toetus</a>.
            Kui teekaart on olemas, võib järgmiseks teemaks olla
            <a href={eisDevelopmentUrl}>digitaliseerimise teekaardi nõustamis- ja arendustegevuste toetus</a>.
          </p>
        </div>
      </section>

      <section id="sobivus" class="ice">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Mida omanik tavaliselt tahab teada</span>
            <h2>Kolm küsimust enne, kui hakkate taotlust või dokumenti tegema.</h2>
          </div>
          <div class="grid-3">
            <article class="card">
              <h3>Kas me üldse sobime?</h3>
              <p>Vaatame läbi ettevõtte suuruse, müügitulu, tegevusala ja senise olukorra.</p>
            </article>
            <article class="card">
              <h3>Mis peab teekaardis olema?</h3>
              <p>Kirja tuleb panna hetkeolukord, kitsaskohad, prioriteedid, maksumus, tasuvus ja riskid.</p>
            </article>
            <article class="card">
              <h3>Mis kasu sellest tuleb?</h3>
              <p>Hea teekaart aitab otsustada, mida arendada esimesena ja mida mitte rahastada.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="kuidas" class="navy">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Meie tööviis</span>
            <h2>Teeme enne pildi selgeks, siis otsustame mahu.</h2>
            <p>See sobib omanikule, kes ei taha alustada pika konsultatsiooniga enne, kui sobivus on arusaadav.</p>
          </div>
          <div class="roadmap">
            <div class="roadmap-item"><strong>01</strong><div><h3>Esmane kontroll</h3><p>Kas EIS meede ja ettevõtte olukord sobivad kokku?</p></div></div>
            <div class="roadmap-item"><strong>02</strong><div><h3>Kitsaskohtade kaart</h3><p>Millised tööd, andmed ja süsteemid praegu ettevõtet pidurdavad?</p></div></div>
            <div class="roadmap-item"><strong>03</strong><div><h3>Teekaardi koostamine</h3><p>Paneme prioriteedid, maksumuse, riskid ja järgmised sammud omaniku keeles kirja.</p></div></div>
          </div>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Mida saate</span>
            <h2>Selge otsus: kas minna toetusega edasi või mitte.</h2>
          </div>
          <div class="grid-2">
            <article class="card">
              <h3>Esimene kõne / eelhindamine</h3>
              <ul class="check">
                <li>kontrollime peamised sobivuse punktid</li>
                <li>ütleme, mis info tuleb kokku koguda</li>
                <li>anname hinnangu, kas tasub edasi minna</li>
              </ul>
            </article>
            <article class="card">
              <h3>Teekaardi töö</h3>
              <ul class="check">
                <li>hetkeolukord ja kitsaskohad</li>
                <li>prioriteedid ja 3 aasta tegevuskava</li>
                <li>maksumus, tasuvus, riskid ja küberturvalisus</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section id="naidis" class="white">
        <div class="section-inner report-sample">
          <div>
            <span class="kicker">Mida saate pärast vormi</span>
            <h2>Näidis: selge eelhinnang ja võimalikud teed edasi.</h2>
            <p>
              Saate lühikese otsuse lehe: kas tasub edasi kontrollida, millised toetusvariandid
              võivad sobida, mida saate ise edasi teha ja millise töö saame meie teie eest ära teha.
              See ei ole EIS-i ametlik otsus, vaid omaniku praktiline otsuse abivahend.
            </p>
            <ul class="check">
              <li>eelhinnang sobivusele ja riskidele</li>
              <li>2-3 võimalikku teed: ise edasi, digiteekaart või väiksem tarkvara/liidestus</li>
              <li>meie ettepanek: mida teha, kui kaua see võtab ja mis hinnaraamis liikuda</li>
            </ul>
            <div class="inline-actions">
              <a class="btn btn-primary" href="#eelhindamine" data-track-event="cta_click" data-track-label="sample_section_eelhindamine">Soovin eelhinnangut</a>
              <a class="btn btn-light" href="/naidisaruanne/" data-track-event="sample_report_click" data-track-label="sample_section_report">Ava näidisaruanne</a>
              <a class="btn btn-light" href="/musterteekaart/" data-track-event="sample_roadmap_click" data-track-label="sample_section_roadmap">Vaata musterteekaarti</a>
              <a class="btn btn-light" href="/pdf-vorm/" data-track-event="pdf_template_click" data-track-label="sample_section_pdf">Vaata PDF vormi</a>
            </div>
          </div>
          <figure class="report-preview-card report-preview-window">
            <a class="report-window-link" href="/pdf-vorm/" aria-label="Ava PDF vormi näidis" data-track-event="pdf_template_click" data-track-label="homepage_pdf_window">
              <div class="report-window-top">
                <strong>PDF eelhinnangu näidis</strong>
                <span>1 tööpäev</span>
              </div>
              <div class="report-window-body">
                <span class="status-tag status-green">Esialgne otsus</span>
                <h3>Tasub edasi kontrollida.</h3>
                <p>Võimalik esimene toetus: kuni 10 000 €, kui tingimused sobivad.</p>
                <div class="report-window-options">
                  <div><strong>1</strong><span>Ise edasi</span></div>
                  <div><strong>2</strong><span>Digiteekaart</span></div>
                  <div><strong>3</strong><span>RTE liidestus</span></div>
                </div>
                <div class="report-window-offer">
                  <strong>Meie ettepanek</strong>
                  <span>15 minuti kõne, seejärel töömaht ja hind.</span>
                </div>
              </div>
            </a>
            <figcaption>Näidis sellest, mida saab omanik pärast eelhindamist e-mailiga.</figcaption>
          </figure>
        </div>
      </section>

      <section id="eelhindamine" class="ice">
        <div class="section-inner lead-section">
          <div class="lead-promise">
            <span class="kicker">Tasuta eelhindamine</span>
            <h2>Saate kohe esmase vastuse ja ühe tööpäeva jooksul kontrollitud vastuse.</h2>
            <p>
              Sisestage ettevõtte nimi, müügitulu suurusjärk ja mida tahate korda teha.
              Leht näitab kohe, milline toetus võib sobida. Meie vaatame seejärel andmed üle
              ja saadame lihtsa omaniku vastuse.
            </p>
            <div class="promise-card">
              <strong>Mida te pärast vormi saate?</strong>
              <ul class="check">
                <li>kas ettevõttel paistab olevat mõistlik võimalus edasi minna</li>
                <li>milline toetus on esmapilgul kõige loogilisem</li>
                <li>mida saate ise edasi teha ja millised riskid tuleb üle kontrollida</li>
                <li>meie ettepanek järgmise töö teostamiseks koos hinnaraamiga</li>
              </ul>
              <a href="/pdf-vorm/" data-track-event="pdf_template_click" data-track-label="lead_section_pdf">Vaadake PDF vastuse näidist</a>
            </div>
            <div class="funding-teaser">
              <span>Esimene rahaline pilt</span>
              <strong>kuni 10 000 €</strong>
              <p>digiteekaardi toetust või kuni 5 000 € väikse tarkvara/liidestuse toetust, kui tingimused sobivad.</p>
            </div>
          </div>

          <form
            class="lead-form"
            data-site-lead-form
            data-webhook-url={leadWebhookUrl}
            data-source-site="digiteekaart.ee"
            data-mail-subject="Digiteekaart.ee - eelhindamine"
            data-support-programs={JSON.stringify(supportPrograms)}
            data-rik-lookup-url={rikLookupUrl}
            data-rik-lookup-key={rikLookupKey}
          >
            <input class="hidden-field" type="text" name="website" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="assessmentSummary" data-assessment-field="summary" />
            <input type="hidden" name="recommendedProgram" data-assessment-field="program" />
            <input type="hidden" name="possibleSupport" data-assessment-field="support" />
            <input type="hidden" name="missingChecks" data-assessment-field="missing" />
            <input type="hidden" name="rikCompanyName" data-rik-field="companyName" />
            <input type="hidden" name="rikCompanyStatus" data-rik-field="statusText" />
            <input type="hidden" name="rikCompanyLegalForm" data-rik-field="legalForm" />
            <input type="hidden" name="rikCompanyAddress" data-rik-field="addressSummary" />
            <input type="hidden" name="rikCheckedAt" data-rik-field="checkedAt" />

            <div class="form-step">
              <span>1</span>
              <div>
                <h3>Ettevõte ja kontakt</h3>
                <p>Kontakt on vajalik, sest toetuse vastus peab minema päris inimesele, mitte anonüümseks testiks.</p>
              </div>
            </div>
            <div class="form-grid">
              <div class="field company-field">
                <label for="company">Ettevõtte nimi *</label>
                <input
                  id="company"
                  name="company"
                  required
                  autocomplete="organization"
                  data-company-search-input
                  aria-autocomplete="list"
                  aria-expanded="false"
                  aria-controls="companySuggestions"
                />
                <div class="company-suggestions" id="companySuggestions" data-company-suggestions hidden role="listbox"></div>
                <p class="field-help" data-company-search-note>Alustage nime kirjutamist. Kui ettevõte ilmub nimekirja, valige see ja registrikood täitub ise.</p>
              </div>
              <div class="field">
                <label for="registryCode">Registrikood</label>
                <input id="registryCode" name="registryCode" inputmode="numeric" pattern="[0-9]{8}" title="Registrikoodis on 8 numbrit" autocomplete="off" />
              </div>
              <div class="rik-lookup-card" data-rik-lookup-status hidden>
                <span class="status-tag status-blue" data-rik-status-label>Kontrollin</span>
                <strong data-rik-company-title>Kontrollin Äriregistrist...</strong>
                <p data-rik-company-detail>Kui registrikood on õige, täidame ettevõtte andmed automaatselt.</p>
              </div>
              <div class="field">
                <label for="person">Teie nimi *</label>
                <input id="person" name="person" required autocomplete="name" />
              </div>
              <div class="field">
                <label for="role">Roll ettevõttes</label>
                <input id="role" name="role" placeholder="Omanik / juhatuse liige / juht" />
              </div>
              <div class="field">
                <label for="email">E-mail *</label>
                <input id="email" name="email" type="email" required autocomplete="email" />
              </div>
              <div class="field">
                <label for="phone">Telefon</label>
                <input id="phone" name="phone" autocomplete="tel" />
              </div>
              <div class="field">
                <label for="companySize">Ettevõtte suurus</label>
                <select id="companySize" name="companySize">
                  <option value="">Valige, kui teate</option>
                  <option>1-4 inimest</option>
                  <option>5-9 inimest</option>
                  <option>10-49 inimest</option>
                  <option>50+ inimest</option>
                </select>
              </div>
              <div class="field">
                <label for="topic">Mis teid praegu huvitab? *</label>
                <select id="topic" name="topic" required>
                  <option>Kas EIS digiteekaardi toetus sobib?</option>
                  <option>Soovin teekaardi koostamise pakkumist</option>
                  <option>Soovin teada, mis infot on vaja</option>
                  <option>Soovin rääkida toetustest ja rahastusest</option>
                </select>
              </div>
            </div>

            <div class="assessment-tool" data-funding-assessment>
              <div class="form-step">
                <span>2</span>
                <div>
                  <h3>10 minuti toetusfilter</h3>
                  <p>Kui täpseid numbreid ei tea, pange ligikaudne suurusjärk. Hiljem kontrollime üle.</p>
                </div>
              </div>

              <div class="form-grid">
                <div class="field">
                  <label for="revenueYear1">Müügitulu eelmisel aastal</label>
                  <input id="revenueYear1" name="revenueYear1" inputmode="numeric" placeholder="Näiteks 180000" data-assessment-input />
                </div>
                <div class="field">
                  <label for="revenueYear2">Müügitulu üle-eelmisel aastal</label>
                  <input id="revenueYear2" name="revenueYear2" inputmode="numeric" placeholder="Näiteks 240000" data-assessment-input />
                </div>
                <div class="field">
                  <label for="deMinimisUsed">VTA kasutatud summa, kui teate</label>
                  <input id="deMinimisUsed" name="deMinimisUsed" inputmode="numeric" placeholder="Kui ei tea, jätke tühjaks" data-assessment-input />
                </div>
                <div class="field">
                  <label for="hasRoadmap">Kas ajakohane digiteekaart on olemas?</label>
                  <select id="hasRoadmap" name="hasRoadmap" data-assessment-input>
                    <option value="unknown">Ei tea / ei ole kindel</option>
                    <option value="yes">Jah</option>
                    <option value="no">Ei</option>
                  </select>
                </div>
                <div class="field full">
                  <label for="fundingNeed">Mida soovite kõige rohkem teada?</label>
                  <select id="fundingNeed" name="fundingNeed" data-assessment-input>
                    <option value="unknown">Ma ei tea veel, millest alustada</option>
                    <option value="software">Mul on selge väike tarkvara või liidestuse töö</option>
                    <option value="roadmap">Meil on mitu ideed ja vaja on järjekorda</option>
                    <option value="development">Digiteekaart on olemas ja nüüd tahame arendada</option>
                    <option value="automation">Tahan suuremat andmevahetust või automatiseerimist</option>
                  </select>
                </div>
                <div class="field full">
                  <label for="message">Kirjutage 2-3 lauset olukorra kohta</label>
                  <textarea id="message" name="message" placeholder="Näiteks: tellimused liiguvad Excelis, tahame CRM-i või andmed automaatselt õigesse kohta."></textarea>
                </div>
              </div>

              <button class="btn btn-light assessment-button" type="button" data-assessment-button>Näita esmast vastust</button>
              <div class="assessment-result" data-assessment-result hidden>
                <div>
                  <span class="status-tag status-blue" data-assessment-status>Esialgne vastus</span>
                  <h3 data-assessment-title>Vastus tekib siin.</h3>
                  <p data-assessment-copy></p>
                </div>
                <div class="assessment-money">
                  <strong>Rahaline pilt</strong>
                  <span data-assessment-money></span>
                  <small data-assessment-detail></small>
                </div>
                <div class="assessment-checks">
                  <strong>Enne päris otsust kontrollime</strong>
                  <ul data-assessment-checks></ul>
                </div>
              </div>
            </div>

            <label class="checkbox">
              <input type="checkbox" name="consentContact" required />
              <span>
                Nõustun, et Ettevõtluskeskus OÜ kasutab minu andmeid eelhindamiseks ja ühenduse võtmiseks.
                <a href="/privaatsus/">Privaatsus</a>
              </span>
            </label>
            <label class="checkbox">
              <input type="checkbox" name="consentFundingUpdates" />
              <span>Soovin saada e-mailiga infot avanevate toetuste ja uute rahastusvõimaluste kohta.</span>
            </label>

            <button class="btn btn-primary" type="submit">Saada eelhindamiseks</button>
            <p class="form-note" data-form-note>Vastame üldjuhul ühe tööpäeva jooksul. Kui süsteem ei saada, avaneb e-kirja varuvariant.</p>
          </form>
        </div>
      </section>

      <section id="kontakt" class="navy">
        <div class="section-inner contact">
          <div>
            <span class="kicker">Järgmine samm</span>
            <h2>Räägime 15 minutiga läbi, kas digiteekaart või väiksem tarkvara toetus on teile mõistlik.</h2>
            <p>
              Kui ettevõte ei sobi või teekaardist ei ole praegu kasu, ütleme seda kohe.
              Kui sobib, lepime kokku, millist infot on vaja ja mis töö maht võiks olla.
            </p>
            <div class="inline-actions">
              <a class="btn btn-primary" href="#eelhindamine" data-track-event="cta_click" data-track-label="footer_eelhindamine">Tee eelhindamine</a>
              <a class="btn btn-secondary" href="tel:+37258180435" data-track-event="phone_click" data-track-label="footer_phone">Helista +372 5818 0435</a>
            </div>
          </div>
          <aside class="contact-card">
            <h3>Kirjutage otse</h3>
            <p>Ettevõtluskeskus OÜ / 02Signal</p>
            <p><a href={emailHref} data-track-event="email_click" data-track-label="contact_card_email">info@02signal.ai</a></p>
            <p><a href="tel:+37258180435" data-track-event="phone_click" data-track-label="contact_card_phone">+372 5818 0435</a></p>
          </aside>
        </div>
      </section>
    </main>

    <Footer />
    <script>
      type SupportProgram = {
        id: string;
        shortName: string;
        supportText: string;
        supportMax: number;
        ownContributionText: string;
        projectRangeText: string;
        minAverageRevenue: number;
        roadmapRequired: boolean;
        ownerAnswer: string;
      };

      type FundingAssessment = {
        status: string;
        program?: SupportProgram;
        title: string;
        copy: string;
        money: string;
        detail: string;
        missing: string[];
        averageRevenue: number;
        deMinimisLeft: number;
      };

      type RikLookupResult = {
        registryCode: string;
        companyName: string | null;
        statusCode: string | null;
        statusText: string | null;
        legalForm: string | null;
        firstRegisteredAt: string | null;
        addressSummary: string | null;
        foundCount: number | null;
        checkedAt: string;
        source: "RIK";
      };

      type RikLookupResponse = {
        result?: RikLookupResult;
        error?: string;
      };

      type CompanySuggestion = {
        registryCode: string;
        companyName: string | null;
        statusCode: string | null;
        legalFormCode: string | null;
        addressSummary: string | null;
        sourceUrl: string | null;
        source: "RIK_AUTOCOMPLETE";
      };

      type CompanySearchResponse = {
        results?: CompanySuggestion[];
        error?: string;
      };

      const parseMoney = (value: FormDataEntryValue | string | null): number => {
        const normalized = String(value || "")
          .replace(/\s/g, "")
          .replace(/€/g, "")
          .replace(",", ".")
          .replace(/[^\d.]/g, "");
        const number = Number(normalized);
        return Number.isFinite(number) ? number : 0;
      };

      const formatEuro = (value: number): string => new Intl.NumberFormat("et-EE", {
        style: "currency",
        currency: "EUR",
        maximumFractionDigits: 0
      }).format(value);

      const readPrograms = (form: HTMLFormElement): SupportProgram[] => {
        try {
          return JSON.parse(form.dataset.supportPrograms || "[]");
        } catch {
          return [];
        }
      };

      const getProgram = (programs: SupportProgram[], id: string): SupportProgram | undefined => programs.find((program: SupportProgram) => program.id === id);

      const makeAssessment = (form: HTMLFormElement): FundingAssessment => {
        const programs = readPrograms(form);
        const data = new FormData(form);
        const revenueYear1 = parseMoney(data.get("revenueYear1"));
        const revenueYear2 = parseMoney(data.get("revenueYear2"));
        const knownRevenueCount = [revenueYear1, revenueYear2].filter((value) => value > 0).length;
        const averageRevenue = knownRevenueCount
          ? Math.round((revenueYear1 + revenueYear2) / knownRevenueCount)
          : 0;
        const deMinimisUsed = parseMoney(data.get("deMinimisUsed"));
        const deMinimisLeft = Math.max(0, 300000 - deMinimisUsed);
        const fundingNeed = String(data.get("fundingNeed") || "unknown");
        const hasRoadmap = String(data.get("hasRoadmap") || "unknown");

        const missing = [];
        if (!averageRevenue) missing.push("kahe viimase aasta müügitulu");
        if (!deMinimisUsed) missing.push("VTA jääk / vähese tähtsusega abi kasutus");
        missing.push("maksuvõla ja varasemate toetuste kontroll");

        let programId = "digital_roadmap";
        if (fundingNeed === "software") programId = "rte_software";
        if (fundingNeed === "development") programId = hasRoadmap === "yes" ? "roadmap_development" : "digital_roadmap";
        if (fundingNeed === "automation") programId = "rte_automation";
        if (fundingNeed === "unknown") {
          if (averageRevenue && averageRevenue < 50000) programId = "rte_software";
          else if (averageRevenue && averageRevenue < 200000) programId = "rte_software";
          else programId = "digital_roadmap";
        }

        const program = getProgram(programs, programId) || programs[0];
        const minRevenue = Number(program?.minAverageRevenue || 0);
        const revenueOk = !minRevenue || averageRevenue >= minRevenue;
        const revenueMissing = !averageRevenue && minRevenue > 0;
        const roadmapMissing = program?.roadmapRequired && hasRoadmap !== "yes";
        const vtaRisk = deMinimisUsed > 0 && deMinimisLeft < Number(program?.supportMax || 0);

        let status = "võib_sobida";
        let title = `${program?.shortName || "Toetus"} võib olla kõige loogilisem esimene tee.`;
        let copy = program?.ownerAnswer || "See vajab lisakontrolli.";

        if (programId === "rte_automation") {
          title = "Suurem RTE automatiseerimine vajab enne kõnet täpsemat kontrolli.";
          copy = "See võib olla hea tee ainult siis, kui andmevahetus, partner või süsteemide ühendus on selgelt kirjeldatud.";
          status = "lisakontroll";
        } else if (roadmapMissing) {
          title = "Kõigepealt tuleb digiteekaart või selle ajakohasus üle vaadata.";
          copy = "Arendustegevuste toetus on tavaliselt järgmine samm pärast ajakohast digiteekaarti.";
          status = "puudub_info";
          missing.unshift("ajakohane digiteekaart");
        } else if (revenueMissing) {
          title = `${program?.shortName || "Toetus"} võib sobida, aga müügitulu on veel puudu.`;
          copy = "Ilma müügitulu suurusjärguta ei saa abikõlblikkust rahulikult hinnata.";
          status = "puudub_info";
        } else if (!revenueOk) {
          title = `Müügitulu järgi ei paista ${program?.shortName || "see toetus"} praegu kindel.`;
          copy = `Sisestatud keskmine müügitulu on umbes ${formatEuro(averageRevenue)}. Selle toetuse esmane piir on ${formatEuro(minRevenue)}. Võib olla mõistlik vaadata väiksemat tööd või rääkida läbi muu tee.`;
          status = "risk";
          if (programId !== "rte_software" && averageRevenue >= 50000) {
            const fallback = getProgram(programs, "rte_software");
            if (fallback) {
              return {
                status: "võib_sobida",
                program: fallback,
                title: "Digiteekaardi asemel võib esimesena sobida väiksem RTE tarkvara või liidestuse toetus.",
                copy: `Sisestatud keskmine müügitulu on umbes ${formatEuro(averageRevenue)}. See ei pruugi digiteekaardi piiri täita, aga võib sobida väiksemale konkreetsele tarkvara või liidestuse tööle.`,
                money: fallback.supportText,
                detail: `${fallback.ownContributionText} omafinantseering, ${fallback.projectRangeText}.`,
                missing,
                averageRevenue,
                deMinimisLeft
              };
            }
          }
        } else if (vtaRisk) {
          title = "VTA jääk võib piirata toetuse summat.";
          copy = "Sisestatud VTA kasutuse järgi võib jääk olla väike. See tuleb enne edasiminekut ametlikult üle kontrollida.";
          status = "risk";
          missing.unshift("VTA jääk ametlikus registris");
        }

        return {
          status,
          program,
          title,
          copy,
          money: program?.supportText || "",
          detail: `${program?.ownContributionText || ""} omafinantseering, ${program?.projectRangeText || ""}.`,
          missing,
          averageRevenue,
          deMinimisLeft
        };
      };

      const writeAssessment = (form: HTMLFormElement, assessment: FundingAssessment): void => {
        const result = form.querySelector("[data-assessment-result]");
        if (!(result instanceof HTMLElement)) return;
        result.hidden = false;

        const status = result.querySelector("[data-assessment-status]");
        const title = result.querySelector("[data-assessment-title]");
        const copy = result.querySelector("[data-assessment-copy]");
        const money = result.querySelector("[data-assessment-money]");
        const detail = result.querySelector("[data-assessment-detail]");
        const checks = result.querySelector("[data-assessment-checks]");

        if (status) {
          status.textContent = assessment.status === "risk" ? "Vajab kontrolli" : assessment.status === "puudub_info" ? "Info puudu" : "Võib sobida";
          status.className = `status-tag ${assessment.status === "risk" ? "status-amber" : assessment.status === "puudub_info" ? "status-amber" : "status-green"}`;
        }
        if (title) title.textContent = assessment.title;
        if (copy) copy.textContent = assessment.copy;
        if (money) money.textContent = assessment.money;
        if (detail) detail.textContent = assessment.detail;
        if (checks) {
          checks.innerHTML = "";
          assessment.missing.slice(0, 5).forEach((item: string) => {
            const li = document.createElement("li");
            li.textContent = item;
            checks.appendChild(li);
          });
        }

        const summary = `${assessment.title} ${assessment.copy}`.trim();
        form.querySelector("[data-assessment-field='summary']")?.setAttribute("value", summary);
        form.querySelector("[data-assessment-field='program']")?.setAttribute("value", assessment.program?.shortName || "");
        form.querySelector("[data-assessment-field='support']")?.setAttribute("value", assessment.money || "");
        form.querySelector("[data-assessment-field='missing']")?.setAttribute("value", assessment.missing.join("; "));

        (window as any).digiteekaartTrack?.("funding_assessment_result", {
          form_name: "digiteekaart_eelhindamine",
          result_status: assessment.status,
          recommended_program: assessment.program?.id || "",
          possible_support: assessment.money || "",
          average_revenue: assessment.averageRevenue || 0
        });
      };

      const normalizeRegistryCode = (value: string): string => value.replace(/\D/g, "").slice(0, 8);

      const setHiddenValue = (form: HTMLFormElement, field: string, value: string): void => {
        const input = form.querySelector(`[data-rik-field='${field}']`);
        if (input instanceof HTMLInputElement) input.value = value;
      };

      const clearRikFields = (form: HTMLFormElement): void => {
        ["companyName", "statusText", "legalForm", "addressSummary", "checkedAt"].forEach((field) => setHiddenValue(form, field, ""));
      };

      const setRikStatus = (form: HTMLFormElement, state: "idle" | "loading" | "success" | "empty" | "error", result?: RikLookupResult): void => {
        const card = form.querySelector("[data-rik-lookup-status]");
        if (!(card instanceof HTMLElement)) return;

        const label = card.querySelector("[data-rik-status-label]");
        const title = card.querySelector("[data-rik-company-title]");
        const detail = card.querySelector("[data-rik-company-detail]");

        card.classList.remove("is-loading", "is-success", "is-error");
        if (state === "idle") {
          card.hidden = true;
          clearRikFields(form);
          return;
        }

        card.hidden = false;
        if (state === "loading") {
          card.classList.add("is-loading");
          if (label) {
            label.textContent = "Kontrollin";
            label.className = "status-tag status-blue";
          }
          if (title) title.textContent = "Kontrollin Äriregistrist...";
          if (detail) detail.textContent = "Üks hetk. Kui kood on õige, täidame ettevõtte andmed automaatselt.";
          return;
        }

        if (state === "success" && result?.companyName) {
          card.classList.add("is-success");
          if (label) {
            label.textContent = "Leitud Äriregistrist";
            label.className = "status-tag status-green";
          }
          if (title) title.textContent = result.companyName;
          const parts = [result.statusText, result.legalForm, result.addressSummary].filter(Boolean);
          if (detail) detail.textContent = parts.length ? parts.join(" · ") : "Ettevõtte põhiandmed leitud.";
          setHiddenValue(form, "companyName", result.companyName || "");
          setHiddenValue(form, "statusText", result.statusText || "");
          setHiddenValue(form, "legalForm", result.legalForm || "");
          setHiddenValue(form, "addressSummary", result.addressSummary || "");
          setHiddenValue(form, "checkedAt", result.checkedAt || "");
          return;
        }

        card.classList.add("is-error");
        clearRikFields(form);
        if (label) {
          label.textContent = state === "empty" ? "Ei leidnud" : "Kontroll käsitsi";
          label.className = "status-tag status-amber";
        }
        if (title) title.textContent = state === "empty" ? "Selle koodiga ettevõtet ei leitud." : "Automaatne kontroll ei õnnestunud.";
        if (detail) detail.textContent = "Võite vormi siiski saata. Kontrollime andmed käsitsi üle.";
      };

      const lookupRikCompany = async (form: HTMLFormElement, registryCode: string, signal?: AbortSignal): Promise<RikLookupResult | null> => {
        const lookupUrl = form.dataset.rikLookupUrl?.trim();
        const lookupKey = form.dataset.rikLookupKey?.trim();
        if (!lookupUrl || !lookupKey) return null;

        const response = await fetch(lookupUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${lookupKey}`,
            "apikey": lookupKey
          },
          body: JSON.stringify({ registryCode }),
          signal
        });

        const body = await response.json() as RikLookupResponse;
        if (!response.ok || body.error) {
          throw new Error(body.error || "rik_lookup_failed");
        }
        return body.result || null;
      };

      const searchRikCompanies = async (form: HTMLFormElement, query: string, signal?: AbortSignal): Promise<CompanySuggestion[]> => {
        const lookupUrl = form.dataset.rikLookupUrl?.trim();
        const lookupKey = form.dataset.rikLookupKey?.trim();
        if (!lookupUrl || !lookupKey) return [];

        const response = await fetch(lookupUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${lookupKey}`,
            "apikey": lookupKey
          },
          body: JSON.stringify({ query }),
          signal
        });

        const body = await response.json() as CompanySearchResponse;
        if (!response.ok || body.error) {
          throw new Error(body.error || "company_search_failed");
        }
        return body.results || [];
      };

      document.querySelectorAll("[data-site-lead-form]").forEach((form) => {
        if (!(form instanceof HTMLFormElement)) return;

        const registryInput = form.querySelector("#registryCode");
        const companyInput = form.querySelector("#company");
        const companySuggestions = form.querySelector("[data-company-suggestions]");
        const companySearchNote = form.querySelector("[data-company-search-note]");
        let rikLookupTimer = 0;
        let rikAbortController: AbortController | null = null;
        let lastRikLookupCode = "";
        let companySearchTimer = 0;
        let companySearchAbortController: AbortController | null = null;
        let lastCompanySearch = "";

        const closeCompanySuggestions = (): void => {
          if (companySuggestions instanceof HTMLElement) {
            companySuggestions.hidden = true;
            companySuggestions.innerHTML = "";
          }
          if (companyInput instanceof HTMLInputElement) {
            companyInput.setAttribute("aria-expanded", "false");
          }
        };

        const setCompanySearchNote = (text: string): void => {
          if (companySearchNote) companySearchNote.textContent = text;
        };

        const runRikLookup = async (registryCode: string): Promise<void> => {
          const normalizedCode = normalizeRegistryCode(registryCode);
          if (normalizedCode.length !== 8) {
            setRikStatus(form, "idle");
            return;
          }
          const knownCompany = form.querySelector("[data-rik-field='companyName']");
          if (lastRikLookupCode === normalizedCode && knownCompany instanceof HTMLInputElement && knownCompany.value) return;

          rikAbortController?.abort();
          rikAbortController = new AbortController();
          setRikStatus(form, "loading");

          try {
            const result = await lookupRikCompany(form, normalizedCode, rikAbortController.signal);
            lastRikLookupCode = normalizedCode;
            if (result?.companyName && Number(result.foundCount || 0) !== 0) {
              setRikStatus(form, "success", result);
              if (companyInput instanceof HTMLInputElement && !companyInput.value.trim()) {
                companyInput.value = result.companyName;
              }
              (window as any).digiteekaartTrack?.("rik_lookup_result", {
                form_name: "digiteekaart_eelhindamine",
                result_status: "found",
                company_status: result.statusText || "",
                registry_code_present: "yes"
              });
            } else {
              setRikStatus(form, "empty", result || undefined);
              (window as any).digiteekaartTrack?.("rik_lookup_result", {
                form_name: "digiteekaart_eelhindamine",
                result_status: "not_found",
                registry_code_present: "yes"
              });
            }
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") return;
            setRikStatus(form, "error");
            (window as any).digiteekaartTrack?.("rik_lookup_result", {
              form_name: "digiteekaart_eelhindamine",
              result_status: "error",
              registry_code_present: "yes"
            });
          }
        };

        const selectCompanySuggestion = (suggestion: CompanySuggestion): void => {
          if (companyInput instanceof HTMLInputElement) {
            companyInput.value = suggestion.companyName || "";
          }
          if (registryInput instanceof HTMLInputElement) {
            registryInput.value = normalizeRegistryCode(suggestion.registryCode);
          }
          closeCompanySuggestions();
          setCompanySearchNote("Ettevõte valitud. Kontrollin nüüd põhiandmed Äriregistrist üle.");
          (window as any).digiteekaartTrack?.("company_autocomplete_select", {
            form_name: "digiteekaart_eelhindamine",
            result_status: suggestion.statusCode || "",
            registry_code_present: suggestion.registryCode ? "yes" : "no"
          });
          void runRikLookup(suggestion.registryCode);
        };

        const renderCompanySuggestions = (suggestions: CompanySuggestion[]): void => {
          if (!(companySuggestions instanceof HTMLElement)) return;
          companySuggestions.innerHTML = "";

          if (!suggestions.length) {
            closeCompanySuggestions();
            setCompanySearchNote("Ei leidnud sobivat ettevõtet. Võite nime ja registrikoodi ise sisestada.");
            return;
          }

          suggestions.slice(0, 6).forEach((suggestion, index) => {
            const button = document.createElement("button");
            button.type = "button";
            button.className = "company-suggestion";
            button.setAttribute("role", "option");
            button.setAttribute("aria-selected", "false");
            button.dataset.index = String(index);

            const name = document.createElement("strong");
            name.textContent = suggestion.companyName || "Nimi puudub";
            const meta = document.createElement("span");
            const parts = [suggestion.registryCode, suggestion.addressSummary].filter(Boolean);
            meta.textContent = parts.join(" · ");

            button.append(name, meta);
            button.addEventListener("mousedown", (event) => event.preventDefault());
            button.addEventListener("click", () => selectCompanySuggestion(suggestion));
            companySuggestions.appendChild(button);
          });

          companySuggestions.hidden = false;
          if (companyInput instanceof HTMLInputElement) {
            companyInput.setAttribute("aria-expanded", "true");
          }
          setCompanySearchNote("Valige õige ettevõte nimekirjast. See täidab registrikoodi automaatselt.");
        };

        const runCompanySearch = async (query: string): Promise<void> => {
          const normalizedQuery = query.replace(/\s+/g, " ").trim();
          if (normalizedQuery.length < 2) {
            closeCompanySuggestions();
            setCompanySearchNote("Alustage nime kirjutamist. Kui ettevõte ilmub nimekirja, valige see ja registrikood täitub ise.");
            return;
          }
          if (lastCompanySearch === normalizedQuery && companySuggestions instanceof HTMLElement && !companySuggestions.hidden) return;

          companySearchAbortController?.abort();
          companySearchAbortController = new AbortController();
          lastCompanySearch = normalizedQuery;
          setCompanySearchNote("Otsin Äriregistrist...");

          try {
            const suggestions = await searchRikCompanies(form, normalizedQuery, companySearchAbortController.signal);
            renderCompanySuggestions(suggestions);
            (window as any).digiteekaartTrack?.("company_autocomplete_result", {
              form_name: "digiteekaart_eelhindamine",
              result_count: suggestions.length,
              query_length: normalizedQuery.length
            });
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") return;
            closeCompanySuggestions();
            setCompanySearchNote("Automaatne otsing ei õnnestunud. Võite nime ja registrikoodi ise sisestada.");
            (window as any).digiteekaartTrack?.("company_autocomplete_result", {
              form_name: "digiteekaart_eelhindamine",
              result_count: 0,
              result_status: "error"
            });
          }
        };

        const scheduleCompanySearch = (): void => {
          if (!(companyInput instanceof HTMLInputElement)) return;
          window.clearTimeout(companySearchTimer);
          companySearchTimer = window.setTimeout(() => {
            void runCompanySearch(companyInput.value);
          }, 350);
        };

        const scheduleRikLookup = (): void => {
          if (!(registryInput instanceof HTMLInputElement)) return;
          const normalizedCode = normalizeRegistryCode(registryInput.value);
          if (registryInput.value !== normalizedCode) registryInput.value = normalizedCode;

          window.clearTimeout(rikLookupTimer);
          if (normalizedCode.length < 8) {
            lastRikLookupCode = "";
            rikAbortController?.abort();
            setRikStatus(form, "idle");
            return;
          }

          rikLookupTimer = window.setTimeout(() => {
            void runRikLookup(normalizedCode);
          }, 450);
        };

        const ensureRikLookup = async (): Promise<void> => {
          if (!(registryInput instanceof HTMLInputElement)) return;
          const normalizedCode = normalizeRegistryCode(registryInput.value);
          if (normalizedCode.length === 8) {
            window.clearTimeout(rikLookupTimer);
            await runRikLookup(normalizedCode);
          }
        };

        if (registryInput instanceof HTMLInputElement) {
          registryInput.addEventListener("input", scheduleRikLookup);
          registryInput.addEventListener("blur", () => {
            window.clearTimeout(rikLookupTimer);
            void ensureRikLookup();
          });
        }

        if (companyInput instanceof HTMLInputElement) {
          companyInput.addEventListener("input", () => {
            const knownCompany = form.querySelector("[data-rik-field='companyName']");
            if (knownCompany instanceof HTMLInputElement && knownCompany.value && companyInput.value.trim() !== knownCompany.value) {
              setRikStatus(form, "idle");
            }
            lastRikLookupCode = "";
            scheduleCompanySearch();
          });
          companyInput.addEventListener("focus", scheduleCompanySearch);
          companyInput.addEventListener("keydown", (event) => {
            if (event.key === "Escape") closeCompanySuggestions();
          });
          companyInput.addEventListener("blur", () => {
            window.setTimeout(closeCompanySuggestions, 180);
          });
        }

        const assessmentButton = form.querySelector("[data-assessment-button]");
        assessmentButton?.addEventListener("click", () => {
          writeAssessment(form, makeAssessment(form));
        });

        form.querySelectorAll("[data-assessment-input]").forEach((input) => {
          input.addEventListener("change", () => {
            if (form.querySelector("[data-assessment-result]:not([hidden])")) {
              writeAssessment(form, makeAssessment(form));
            }
          });
        });

        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          const currentForm = event.currentTarget;
          if (!(currentForm instanceof HTMLFormElement)) return;
          if (!currentForm.checkValidity()) {
            currentForm.reportValidity();
            return;
          }

          const note = currentForm.querySelector("[data-form-note]");
          const submitButton = currentForm.querySelector("button[type='submit']");
          let data = new FormData(currentForm);
          if (data.get("website")) return;
          await ensureRikLookup();
          data = new FormData(currentForm);

          const attribution = (window as any).digiteekaartGetAttribution?.() || {};
          const lastCta = (window as any).digiteekaartGetLastCta?.() || {};
          const assessment = makeAssessment(currentForm);
          writeAssessment(currentForm, assessment);
          const leadId = crypto.randomUUID ? crypto.randomUUID() : `lead-${Date.now()}-${Math.random().toString(16).slice(2)}`;
          const payload = {
            leadId,
            sourceSite: currentForm.dataset.sourceSite,
            sourcePath: window.location.pathname,
            attribution,
            lastCta,
            company: String(data.get("company") || ""),
            registryCode: String(data.get("registryCode") || ""),
            rikCompanyName: String(data.get("rikCompanyName") || ""),
            rikCompanyStatus: String(data.get("rikCompanyStatus") || ""),
            rikCompanyLegalForm: String(data.get("rikCompanyLegalForm") || ""),
            rikCompanyAddress: String(data.get("rikCompanyAddress") || ""),
            rikCheckedAt: String(data.get("rikCheckedAt") || ""),
            person: String(data.get("person") || ""),
            role: String(data.get("role") || ""),
            email: String(data.get("email") || ""),
            phone: String(data.get("phone") || ""),
            companySize: String(data.get("companySize") || ""),
            topic: String(data.get("topic") || ""),
            revenueYear1: String(data.get("revenueYear1") || ""),
            revenueYear2: String(data.get("revenueYear2") || ""),
            averageRevenue: assessment.averageRevenue || 0,
            deMinimisUsed: String(data.get("deMinimisUsed") || ""),
            deMinimisLeft: assessment.deMinimisLeft || 0,
            hasRoadmap: String(data.get("hasRoadmap") || ""),
            fundingNeed: String(data.get("fundingNeed") || ""),
            recommendedProgram: assessment.program?.shortName || "",
            possibleSupport: assessment.money || "",
            assessmentSummary: `${assessment.title} ${assessment.copy}`.trim(),
            missingChecks: assessment.missing.join("; "),
            message: String(data.get("message") || ""),
            consentContact: data.get("consentContact") === "on",
            consentFundingUpdates: data.get("consentFundingUpdates") === "on",
            consentVersion: "2026-05-30"
          };
          const fallbackText = [
            `Ettevõte: ${payload.company}`,
            `Registrikood: ${payload.registryCode || "-"}`,
            `RIK ettevõte: ${payload.rikCompanyName || "-"}`,
            `RIK staatus: ${payload.rikCompanyStatus || "-"}`,
            `RIK vorm: ${payload.rikCompanyLegalForm || "-"}`,
            `RIK aadress: ${payload.rikCompanyAddress || "-"}`,
            `RIK kontrollitud: ${payload.rikCheckedAt || "-"}`,
            `Nimi: ${payload.person}`,
            `Roll: ${payload.role || "-"}`,
            `Email: ${payload.email}`,
            `Telefon: ${payload.phone || "-"}`,
            `Suurus: ${payload.companySize || "-"}`,
            `Teema: ${payload.topic}`,
            `Müügitulu 1: ${payload.revenueYear1 || "-"}`,
            `Müügitulu 2: ${payload.revenueYear2 || "-"}`,
            `Keskmine müügitulu: ${payload.averageRevenue || "-"}`,
            `VTA kasutatud: ${payload.deMinimisUsed || "-"}`,
            `Digiteekaart olemas: ${payload.hasRoadmap || "-"}`,
            `Soov: ${payload.fundingNeed || "-"}`,
            `Soovitatud tee: ${payload.recommendedProgram || "-"}`,
            `Võimalik toetus: ${payload.possibleSupport || "-"}`,
            `Esialgne vastus: ${payload.assessmentSummary || "-"}`,
            `Puuduvad kontrollid: ${payload.missingChecks || "-"}`,
            `Soovin toetuste teateid: ${payload.consentFundingUpdates ? "jah" : "ei"}`,
            `Kanal: ${attribution.utm_source || attribution.referrerHost || "-"}`,
            `Kampaania: ${attribution.utm_campaign || "-"}`,
            `Maandumisleht: ${attribution.landingPath || "-"}`,
            `Viimane nupp: ${lastCta.cta_label || "-"}`,
            "",
            "Sõnum:",
            payload.message || "-"
          ].join("\n");
          const fallbackHref = `mailto:info@02signal.ai?subject=${encodeURIComponent(currentForm.dataset.mailSubject || "Digiteekaart.ee päring")}&body=${encodeURIComponent(fallbackText)}`;

          submitButton?.setAttribute("disabled", "true");
          if (note) note.textContent = "Saadan andmed turvaliselt...";
          (window as any).digiteekaartTrack?.("lead_form_submit_attempt", {
            form_name: "digiteekaart_eelhindamine",
            source_site: payload.sourceSite
          });

          const webhookUrl = currentForm.dataset.webhookUrl?.trim();
          if (webhookUrl) {
            try {
              const response = await fetch(webhookUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
              });
              if (response.ok) {
                currentForm.reset();
                setRikStatus(currentForm, "idle");
                if (note) note.textContent = "Aitäh. Päring on salvestatud ja jõudis meieni. Võtame ühendust ühe tööpäeva jooksul.";
                (window as any).digiteekaartTrack?.("lead_form_submit", {
                  form_name: "digiteekaart_eelhindamine",
                  status: "saved",
                  source_site: payload.sourceSite
                });
                submitButton?.removeAttribute("disabled");
                return;
              }
            } catch {
              // Fallback opens the prepared e-mail below.
            }
          }

          window.location.href = fallbackHref;
          if (note) note.textContent = "Kui e-kiri ei avanenud, kirjutage info@02signal.ai või helistage +372 5818 0435.";
          (window as any).digiteekaartTrack?.("lead_form_submit", {
            form_name: "digiteekaart_eelhindamine",
            status: "mailto_fallback",
            source_site: payload.sourceSite
          });
          submitButton?.removeAttribute("disabled");
        });
      });
    </script>
  </body>
</html>
