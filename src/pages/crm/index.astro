---
import "../../styles/global.css";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? "https://miwpctshbcmkpwvdokne.supabase.co";
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "";
---

<!doctype html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <title>Digiteekaart CRM | Müügi töölaud</title>
  </head>
  <body class="crm-page">
    <main class="crm-shell">
      <section class="crm-panel crm-login" data-login-view>
        <div>
          <span class="kicker">Sisemine töölaud</span>
          <h1>Digiteekaart CRM</h1>
          <p>
            Logi sisse oma töö e-mailiga. Link saadetakse e-mailile ja avaneb samas brauseris.
          </p>
        </div>

        <form class="crm-login-form" data-login-form>
          <label for="crm-email">E-mail</label>
          <div class="crm-login-row">
            <input id="crm-email" name="email" type="email" autocomplete="email" placeholder="nimi@ettevotluskeskus.ee" required />
            <button class="btn btn-primary" type="submit">Saada link</button>
          </div>
          <p class="crm-message" data-login-message></p>
        </form>

        <div class="crm-note">
          Kui link jõuab kohale, vajuta seda samas seadmes. Kui sisse ei saa, peab administraator lisama teie e-maili
          CRM-i kasutajate plokis.
        </div>
      </section>

      <section class="crm-app" data-app-view hidden>
        <header class="crm-header">
          <div>
            <span class="kicker">Müügi töölaud</span>
            <h1>Millisele firmale täna helistada?</h1>
            <p>Üks kaart, üks signaal, üks järgmine samm. Täpsem info avaneb ainult siis, kui seda vaja on.</p>
          </div>
          <div class="crm-user-box">
            <span data-user-email></span>
            <button class="btn btn-light" type="button" data-sign-out>Logi välja</button>
          </div>
        </header>

        <div class="crm-metrics" data-metrics></div>

        <details class="crm-panel crm-score-model">
          <summary>
            <span>
              <strong>Kuidas skoor tekib?</strong>
              <em>75+ tähendab: hea kandidaat esimeseks kõneks.</em>
            </span>
          </summary>
          <div class="crm-score-model-body">
            <div>
              <span class="kicker">Lead'i tugevuse mudel</span>
              <h2>Miks see firma on nimekirjas?</h2>
              <p>
                Skoor põhineb avalikel ettevõtte faktidel. VTA kontrollimata tähendab: enne pakkumist tuleb jääk üle vaadata.
              </p>
            </div>
            <div class="crm-criteria-grid" data-criteria-list></div>
            <p class="crm-score-note">
              Kõne kinnitab alati kolm asja: kas plaan on päris, kas toetus sobib ja kas VTA jääk on hetkel piisav.
            </p>
          </div>
        </details>

        <section class="crm-panel crm-admin" data-admin-panel hidden>
          <div class="crm-admin-head">
            <div>
              <span class="kicker">Admin</span>
              <h2>Kasutajad</h2>
              <p>Lisa ainult inimesed, kellel peab olema ligipääs sisemisele CRM-ile.</p>
            </div>
            <button class="btn btn-light" type="button" data-users-refresh>Värskenda kasutajaid</button>
          </div>

          <form class="crm-user-form" data-user-form>
            <label>
              E-mail
              <input name="email" type="email" autocomplete="email" placeholder="nimi@ettevotluskeskus.ee" required />
            </label>
            <label>
              Roll
              <select name="role">
                <option value="sales">Müük</option>
                <option value="admin">Admin</option>
              </select>
            </label>
            <button class="btn btn-primary" type="submit">Lisa kasutaja</button>
          </form>

          <div class="crm-users-list" data-users-list></div>
          <p class="crm-message" data-users-message></p>
        </section>

        <div class="crm-view-tabs" data-view-filter>
          <button class="is-active" type="button" data-view="strong">Tugev signaal</button>
          <button type="button" data-view="all">Kõik andmebaasis</button>
          <button type="button" data-view="prospects">Müüki lisatud</button>
        </div>

        <section class="crm-panel crm-filters" aria-label="Filtrid">
          <label>
            Otsi
            <input data-search type="search" placeholder="Firma nimi, registrikood või tegevusala" />
          </label>
          <label>
            Staatus
            <select data-status-filter>
              <option value="">Kõik</option>
              <option value="not_in_sales">Ainult andmebaasis</option>
              <option value="new">Uus</option>
              <option value="call_next">Helista järgmisena</option>
              <option value="to_review">Vajab ülevaatust</option>
              <option value="called">Helistatud</option>
              <option value="meeting_booked">Kohtumine kokku lepitud</option>
              <option value="proposal_sent">Pakkumine saadetud</option>
              <option value="not_relevant">Ei sobi</option>
            </select>
          </label>
          <label>
            VTA
            <select data-vta-filter>
              <option value="">Kõik</option>
              <option value="high_left">Suur jääk</option>
              <option value="some_left">Jääk olemas</option>
              <option value="not_checked">Kontrollimata</option>
              <option value="low_left">Väike jääk</option>
              <option value="used_up">Kasutatud</option>
            </select>
          </label>
          <label>
            Min skoor
            <input data-score-filter type="number" min="0" max="100" step="5" value="0" />
          </label>
          <button class="btn btn-secondary crm-refresh" type="button" data-refresh>Värskenda</button>
          <button class="btn btn-primary crm-refresh" type="button" data-queue-top-vta>Käivita 10 VTA</button>
        </section>

        <section class="crm-workspace" aria-label="Müügi töölaud">
          <div class="crm-kanban" data-kanban-board></div>

          <aside class="crm-panel crm-company-sheet" data-detail-panel hidden>
            <div class="crm-sheet-empty">
              Vali ettevõte, et näha lühikest töölehte, kõnespikkerit ja andmete ajalugu.
            </div>
            <div data-detail-content></div>
          </aside>
        </section>

        <section class="crm-panel crm-board-status">
          <div class="crm-empty" data-empty-state hidden>
            Andmeid ei ole veel näidata. Kui olete sisse logitud, tuleb järgmine samm: SQL migratsioon Supabase’is ja esimese RIK avalike andmete impordi käivitamine.
          </div>
          <p class="crm-message" data-board-message></p>
        </section>
      </section>
    </main>

    <div
      hidden
      data-crm-config
      data-supabase-url={supabaseUrl}
      data-supabase-anon-key={supabaseAnonKey}
    ></div>

    <script is:inline type="module">
      import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

      const crmConfig = document.querySelector("[data-crm-config]");
      const supabaseUrl = crmConfig?.getAttribute("data-supabase-url") || "";
      const supabaseAnonKey = crmConfig?.getAttribute("data-supabase-anon-key") || "";
      const loginView = document.querySelector("[data-login-view]");
      const appView = document.querySelector("[data-app-view]");
      const loginForm = document.querySelector("[data-login-form]");
      const loginMessage = document.querySelector("[data-login-message]");
      const boardMessage = document.querySelector("[data-board-message]");
      const kanbanBoard = document.querySelector("[data-kanban-board]");
      const detailPanel = document.querySelector("[data-detail-panel]");
      const detailContent = document.querySelector("[data-detail-content]");
      const emptyState = document.querySelector("[data-empty-state]");
      const metrics = document.querySelector("[data-metrics]");
      const criteriaList = document.querySelector("[data-criteria-list]");
      const userEmail = document.querySelector("[data-user-email]");
      const signOutButton = document.querySelector("[data-sign-out]");
      const refreshButton = document.querySelector("[data-refresh]");
      const queueTopVtaButton = document.querySelector("[data-queue-top-vta]");
      const viewFilter = document.querySelector("[data-view-filter]");
      const adminPanel = document.querySelector("[data-admin-panel]");
      const usersRefreshButton = document.querySelector("[data-users-refresh]");
      const userForm = document.querySelector("[data-user-form]");
      const usersList = document.querySelector("[data-users-list]");
      const usersMessage = document.querySelector("[data-users-message]");
      const searchInput = document.querySelector("[data-search]");
      const statusFilter = document.querySelector("[data-status-filter]");
      const vtaFilter = document.querySelector("[data-vta-filter]");
      const scoreFilter = document.querySelector("[data-score-filter]");

      const statusLabels = {
        new: "Uus",
        to_review: "Vajab ülevaatust",
        call_next: "Helista järgmisena",
        called: "Helistatud",
        not_relevant: "Ei sobi",
        meeting_booked: "Kohtumine",
        proposal_sent: "Pakkumine",
        won: "Võidetud",
        lost: "Kaotatud",
        do_not_contact: "Ära võta ühendust",
        not_in_sales: "Ainult andmebaasis"
      };

      const vtaLabels = {
        not_checked: "Kontrollimata",
        high_left: "Suur jääk",
        some_left: "Jääk olemas",
        low_left: "Väike jääk",
        used_up: "Kasutatud",
        manual_review: "Vajab käsitsi kontrolli",
        source_unavailable: "Allikas ei vastanud"
      };

      const actionButtons = [
        ["call_next", "Helista"],
        ["called", "Helistatud"],
        ["meeting_booked", "Kohtumine"],
        ["proposal_sent", "Pakkumine"],
        ["not_relevant", "Ei sobi"],
        ["do_not_contact", "Ära võta"]
      ];

      const kanbanColumns = [
        {
          id: "todo",
          title: "Tee täna",
          hint: "Uued signaalid ja VTA kontroll",
          matches: (row) => ["not_in_sales", "new", "to_review", "call_next"].includes(row.crm_status)
        },
        {
          id: "doing",
          title: "Töös",
          hint: "Kõne, kohtumine või pakkumine",
          matches: (row) => ["called", "meeting_booked", "proposal_sent"].includes(row.crm_status)
        },
        {
          id: "done",
          title: "Lõpetatud",
          hint: "Ei sobi või ära puutu",
          matches: (row) => ["not_relevant", "do_not_contact", "won", "lost"].includes(row.crm_status)
        }
      ];

      const state = {
        session: null,
        currentUser: null,
        rows: [],
        users: [],
        criteria: [],
        stats: null,
        view: "strong",
        selectedRegistryCode: null
      };

      const formatMoney = (value) => {
        if (value === null || value === undefined || value === "") return "-";
        return new Intl.NumberFormat("et-EE", {
          style: "currency",
          currency: "EUR",
          maximumFractionDigits: 0
        }).format(Number(value));
      };

      const formatCompactMoney = (value) => {
        if (value === null || value === undefined || value === "") return "käive ?";
        const amount = Number(value);
        if (!Number.isFinite(amount)) return "käive ?";
        if (Math.abs(amount) >= 1000000) {
          const decimals = Math.abs(amount) >= 10000000 ? 0 : 1;
          return `${new Intl.NumberFormat("et-EE", { maximumFractionDigits: decimals }).format(amount / 1000000)} mln €`;
        }
        if (Math.abs(amount) >= 1000) {
          return `${new Intl.NumberFormat("et-EE", { maximumFractionDigits: 0 }).format(amount / 1000)} tuh €`;
        }
        return `${new Intl.NumberFormat("et-EE", { maximumFractionDigits: 0 }).format(amount)} €`;
      };

      const formatDate = (value) => {
        if (!value) return "-";
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return "-";
        return new Intl.DateTimeFormat("et-EE", {
          day: "2-digit",
          month: "2-digit",
          year: "numeric"
        }).format(date);
      };

      const safeText = (value) => String(value ?? "").trim();

      const escapeHtml = (value) => safeText(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        "\"": "&quot;",
        "'": "&#39;"
      }[char]));

      const setMessage = (target, text, type = "") => {
        target.textContent = text;
        target.dataset.type = type;
      };

      const signalLabel = (row) => {
        const score = Number(row.priority_score || 0);
        if (score >= 75) return "Tugev signaal";
        if (score >= 50) return "Vajab ülevaatust";
        return "Madal prioriteet";
      };

      const signalTone = (row) => {
        const score = Number(row.priority_score || 0);
        if (score >= 75) return "strong";
        if (score >= 50) return "medium";
        return "low";
      };

      const vtaStatusLabel = (row) => {
        if (row.vta_queue_status === "queued") return "VTA järjekorras";
        if (row.vta_queue_status === "checking") return "VTA kontrollis";
        if (row.vta_queue_status === "checked") return "VTA kontrollitud";
        if (row.vta_queue_status === "manual_review") return "VTA vajab ülevaatust";
        if (row.vta_queue_status === "failed") return "VTA tõrge";
        if (row.vta_queue_status === "skipped") return "VTA vahele jäetud";
        return vtaLabels[row.vta_signal] || row.vta_signal || "-";
      };

      const vtaSummary = (row) => {
        if (row.vta_queue_status === "queued") {
          return { label: "VTA taustal", hint: "tulemus tuleb siia", state: "running" };
        }
        if (row.vta_queue_status === "checking") {
          return { label: "Kontrollib", hint: "päring käib", state: "running" };
        }
        if (row.vta_queue_status === "checked") {
          return {
            label: "VTA tehtud",
            hint: row.de_minimis_left === null || row.de_minimis_left === undefined ? "jääk teadmata" : `${formatCompactMoney(row.de_minimis_left)} jääk`,
            state: "checked"
          };
        }
        if (row.vta_queue_status === "manual_review") {
          return { label: "Kontrolli üle", hint: "vajab inimest", state: "risk" };
        }
        if (row.vta_queue_status === "failed") {
          return { label: "VTA tõrge", hint: "proovi hiljem", state: "risk" };
        }
        if (row.vta_queue_status === "skipped") {
          return { label: "VTA vahele", hint: "ei kontrollitud", state: "unknown" };
        }
        if (row.vta_signal === "high_left" || row.vta_signal === "some_left") {
          return {
            label: "VTA jääk olemas",
            hint: row.de_minimis_left === null || row.de_minimis_left === undefined ? "kontrolli üle" : `${formatCompactMoney(row.de_minimis_left)} jääk`,
            state: "good"
          };
        }
        if (row.vta_signal === "low_left" || row.vta_signal === "used_up") {
          return { label: "VTA risk", hint: "ära paku enne kontrolli", state: "risk" };
        }
        return { label: "VTA teadmata", hint: "kontrolli enne pakkumist", state: "unknown" };
      };

      const vtaActionLabel = (row) => {
        if (row.vta_queue_status === "queued") return "VTA taustal";
        if (row.vta_queue_status === "checking") return "Kontrollib";
        if (row.vta_queue_status === "checked") return "Uuenda VTA";
        if (row.vta_queue_status === "failed") return "Proovi VTA uuesti";
        if (row.vta_queue_status === "manual_review") return "Uuenda VTA";
        return "Käivita VTA";
      };

      const scoreParts = (row) => {
        if (!Array.isArray(row.score_breakdown)) return [];
        return row.score_breakdown.map((part) => ({
          label: safeText(part.label),
          points: Number(part.points || 0),
          maxPoints: Number(part.max_points || 0)
        }));
      };

      const findRow = (registryCode) =>
        state.rows.find((row) => row.registry_code === registryCode);

      const supabase = supabaseAnonKey
        ? createClient(supabaseUrl, supabaseAnonKey, {
            auth: {
              detectSessionInUrl: true,
              persistSession: true,
              autoRefreshToken: true
            }
          })
        : null;

      const showLogin = () => {
        loginView.hidden = false;
        appView.hidden = true;
      };

      const showApp = () => {
        loginView.hidden = true;
        appView.hidden = false;
      };

      const crmRedirectUrl = () => {
        const url = new URL("/crm/", window.location.origin);
        return url.toString();
      };

      const renderUsers = () => {
        usersList.innerHTML = state.users.map((user) => {
          const isSelf = state.currentUser?.email === user.email;
          const actionLabel = user.active ? "Lülita välja" : "Tee aktiivseks";
          return `
            <article class="crm-user-row">
              <div>
                <strong>${escapeHtml(user.email)}</strong>
                <span>${user.role === "admin" ? "Admin" : "Müük"} · ${user.active ? "aktiivne" : "välja lülitatud"}</span>
              </div>
              <button
                type="button"
                data-user-active-toggle="${escapeHtml(user.email)}"
                data-next-active="${user.active ? "false" : "true"}"
                ${isSelf && user.active ? "disabled" : ""}
              >${actionLabel}</button>
            </article>
          `;
        }).join("");
      };

      const loadCurrentUser = async () => {
        const { data, error } = await supabase.rpc("crm_get_current_user");
        if (error) {
          state.currentUser = null;
          return;
        }
        state.currentUser = Array.isArray(data) && data.length ? data[0] : null;
        adminPanel.hidden = state.currentUser?.role !== "admin";
      };

      const renderCriteria = () => {
        if (!state.criteria.length) {
          criteriaList.innerHTML = "<article><strong>Skoorimudel laadimata</strong><span>Värskenda CRM-i või kontrolli kasutaja ligipääsu.</span></article>";
          return;
        }

        criteriaList.innerHTML = state.criteria.map((criterion) => `
          <article>
            <strong>${escapeHtml(criterion.label)} <b>${criterion.max_points}p</b></strong>
            <span>${escapeHtml(criterion.plain_rule)}</span>
            <em>${escapeHtml(criterion.strong_signal_note)}</em>
          </article>
        `).join("");
      };

      const loadCriteriaAndStats = async () => {
        const [criteriaResult, statsResult] = await Promise.all([
          supabase.rpc("crm_get_lead_scoring_criteria"),
          supabase.rpc("crm_get_warehouse_stats")
        ]);

        state.criteria = Array.isArray(criteriaResult.data) ? criteriaResult.data : [];
        state.stats = Array.isArray(statsResult.data) && statsResult.data.length ? statsResult.data[0] : null;

        renderCriteria();
      };

      const loadUsers = async () => {
        if (adminPanel.hidden) return;

        setMessage(usersMessage, "Laen kasutajaid...", "");
        const { data, error } = await supabase.rpc("crm_list_users");

        if (error) {
          setMessage(usersMessage, `Kasutajate laadimine ei õnnestunud: ${error.message}`, "error");
          state.users = [];
          renderUsers();
          return;
        }

        state.users = Array.isArray(data) ? data : [];
        renderUsers();
        setMessage(usersMessage, state.users.length ? "Kasutajad laetud." : "Kasutajaid ei ole.", state.users.length ? "ok" : "");
      };

      const addUser = async (form) => {
        const formData = new FormData(form);
        const email = safeText(formData.get("email")).toLowerCase();
        const role = safeText(formData.get("role")) || "sales";

        setMessage(usersMessage, "Lisan kasutajat...", "");
        const { error } = await supabase.rpc("crm_upsert_user", {
          p_email: email,
          p_role: role,
          p_active: true
        });

        if (error) {
          setMessage(usersMessage, `Kasutajat ei saanud lisada: ${error.message}`, "error");
          return;
        }

        form.reset();
        setMessage(usersMessage, "Kasutaja lisatud.", "ok");
        await loadUsers();
      };

      const setUserActive = async (email, active) => {
        setMessage(usersMessage, "Uuendan kasutajat...", "");
        const { error } = await supabase.rpc("crm_set_user_active", {
          p_email: email,
          p_active: active
        });

        if (error) {
          setMessage(usersMessage, `Kasutajat ei saanud muuta: ${error.message}`, "error");
          return;
        }

        setMessage(usersMessage, "Kasutaja uuendatud.", "ok");
        await loadUsers();
      };

      const renderMetrics = () => {
        const stats = state.stats || {};
        const rows = state.rows;
        const imported = stats.imported_companies ?? rows.length;
        const scored = stats.scored_companies ?? rows.length;
        const strong = stats.strong_leads ?? rows.filter((row) => row.priority_score >= 75).length;
        const prospects = stats.prospects ?? rows.filter((row) => row.is_prospect).length;
        const unchecked = stats.unchecked_vta ?? rows.filter((row) => row.vta_signal === "not_checked").length;
        const queued = rows.filter((row) => row.vta_queue_status === "queued").length;

        metrics.innerHTML = `
          <article><strong>${imported}</strong><span>firmat andmebaasis</span></article>
          <article><strong>${scored}</strong><span>skooritud firmat</span></article>
          <article><strong>${strong}</strong><span>tugev signaal</span></article>
          <article><strong>${prospects}</strong><span>müüki lisatud</span></article>
          <article><strong>${unchecked}</strong><span>VTA kontrollimata</span></article>
          <article><strong>${queued}</strong><span>VTA järjekorras</span></article>
        `;
      };

      const filteredRows = () => {
        const search = safeText(searchInput.value).toLowerCase();
        const status = statusFilter.value;
        const vta = vtaFilter.value;
        const minScore = Number(scoreFilter.value || 0);

        return state.rows.filter((row) => {
          if (state.view === "strong" && Number(row.priority_score || 0) < 75) return false;
          if (state.view === "prospects" && !row.is_prospect) return false;

          const text = [
            row.company_name,
            row.registry_code,
            row.primary_activity_name,
            row.recommended_pitch,
            ...(row.score_reason || [])
          ].join(" ").toLowerCase();

          if (search && !text.includes(search)) return false;
          if (status && row.crm_status !== status) return false;
          if (vta && row.vta_signal !== vta) return false;
          if (Number(row.priority_score || 0) < minScore) return false;
          return true;
        });
      };

      const renderCardActions = (row, compact = true) => {
        const registryCode = escapeHtml(row.registry_code);
        const vtaRunning = row.vta_queue_status === "queued" || row.vta_queue_status === "checking";
        const detailButton = `<button class="crm-action-secondary" type="button" data-detail-code="${registryCode}">Ava</button>`;
        const vtaButton = `<button class="crm-action-primary" type="button" data-vta-code="${registryCode}" ${vtaRunning ? "disabled" : ""}>${vtaActionLabel(row)}</button>`;

        if (!row.is_prospect) {
          return compact
            ? `${vtaButton}${detailButton}<button class="crm-action-secondary" type="button" data-promote-code="${registryCode}">Lisa müüki</button>`
            : `${detailButton}${vtaButton}<button class="crm-action-secondary" type="button" data-promote-code="${registryCode}">Lisa müüki</button>`;
        }

        if (compact) {
          return `${vtaButton}${detailButton}<button class="crm-action-secondary" type="button" data-status-action="called" data-prospect-id="${row.prospect_id}">Helistatud</button>`;
        }

        const statusButtons = actionButtons.map(([status, label]) => (
          `<button type="button" data-status-action="${status}" data-prospect-id="${row.prospect_id}">${label}</button>`
        )).join("");

        return `${detailButton}${vtaButton}${statusButtons}`;
      };

      const renderCompanyCard = (row) => {
        const selected = state.selectedRegistryCode === row.registry_code ? " is-selected" : "";
        const employeeText = row.latest_employee_count === null || row.latest_employee_count === undefined
          ? "töötajaid ?"
          : `${row.latest_employee_count} töötajat`;
        const ageText = row.company_age_years === null || row.company_age_years === undefined
          ? "vanus ?"
          : `${row.company_age_years} a`;
        const firstReason = safeText((row.score_reason || []).find(Boolean)) || "vaata detaili";
        const vta = vtaSummary(row);

        return `
          <article class="crm-lead-card crm-signal-${signalTone(row)}${selected}" data-card-code="${escapeHtml(row.registry_code)}">
            <header>
              <div>
                <strong class="crm-card-title">${escapeHtml(row.company_name)}</strong>
                <span>${escapeHtml(row.registry_code)} · ${escapeHtml(statusLabels[row.crm_status] || row.crm_status)}</span>
              </div>
              <b>${row.priority_score ?? 0}</b>
            </header>
            <div class="crm-signal-line">
              <span>${escapeHtml(signalLabel(row))}</span>
              <strong>${escapeHtml(firstReason)}</strong>
            </div>
            <div class="crm-signal-chips">
              <span>${escapeHtml(ageText)}</span>
              <span>${escapeHtml(employeeText)}</span>
              <span>${formatCompactMoney(row.average_revenue_last_two)}</span>
            </div>
            <div class="crm-vta-mini" data-vta-state="${escapeHtml(vta.state)}">
              <strong>${escapeHtml(vta.label)}</strong>
              <span>${escapeHtml(vta.hint)}</span>
            </div>
            <div class="crm-row-actions">${renderCardActions(row)}</div>
          </article>
        `;
      };

      const renderDetail = (registryCode) => {
        const row = findRow(registryCode);
        if (!row) {
          detailPanel.hidden = true;
          detailContent.innerHTML = "";
          return;
        }

        detailPanel.hidden = false;

        const scoreRows = scoreParts(row).map((part) => `
          <li>
            <span>${escapeHtml(part.label)}</span>
            <strong>${part.points}/${part.maxPoints}</strong>
          </li>
        `).join("");

        const historyRows = [
          ["Registrisse kantud", formatDate(row.registered_at)],
          ["Vanus", `${row.company_age_years ?? "-"} aastat`],
          ["Viimane aruandeaasta", row.latest_fiscal_year || "-"],
          ["Keskmine müügitulu", formatMoney(row.average_revenue_last_two)],
          ["Töötajaid", row.latest_employee_count ?? "teadmata"],
          ["Asukoht", row.address_summary || "-"],
          ["VTA seis", vtaStatusLabel(row)],
          ["VTA kontrollitud", formatDate(row.de_minimis_checked_at)],
          ["VTA järjekord", row.vta_queue_status ? `${vtaStatusLabel(row)} · ${formatDate(row.vta_scheduled_for)}` : "ei ole järjekorras"],
          ["Viimane CRM puudutus", formatDate(row.last_contacted_at)]
        ].map(([label, value]) => `
          <li>
            <span>${escapeHtml(label)}</span>
            <strong>${escapeHtml(value)}</strong>
          </li>
        `).join("");

        const reasons = [...(row.score_reason || [])]
          .filter(Boolean)
          .map((reason) => `<span>${escapeHtml(reason)}</span>`)
          .join("");

        const sheetUrl = `${window.location.origin}/crm/#firma=${encodeURIComponent(row.registry_code)}`;

        detailContent.innerHTML = `
          <div class="crm-sheet-head">
            <div>
              <span class="kicker">Firma tööleht</span>
              <h2>${escapeHtml(row.company_name)}</h2>
              <p>${escapeHtml(row.registry_code)} · ${escapeHtml(row.company_status) || "staatus teadmata"}</p>
            </div>
            <button class="crm-sheet-close" type="button" data-close-detail aria-label="Sulge">×</button>
          </div>

          <div class="crm-sheet-score">
            <strong>${row.priority_score ?? 0}/100</strong>
            <span>${signalLabel(row)}</span>
          </div>

          <section>
            <h3>Miks see on huvitav</h3>
            <div class="crm-tags">${reasons || "<span>Vajab ülevaatust</span>"}</div>
          </section>

          <details class="crm-sheet-section">
            <summary>Skoori põhimõte</summary>
            <ul class="crm-sheet-list">${scoreRows}</ul>
          </details>

          <details class="crm-sheet-section">
            <summary>Ajaloolised märgid</summary>
            <ul class="crm-sheet-list">${historyRows}</ul>
            <p class="crm-sheet-note">VTA jääk ei ole püsiv hinnang. Enne pakkumist tuleb see päringu hetkel üle kontrollida ja tulemus andmebaasi salvestada.</p>
          </details>

          <section>
            <h3>Esimese kõne mõte</h3>
            <p class="crm-pitch">${escapeHtml(row.recommended_pitch)}</p>
            <button class="btn btn-light" type="button" data-copy-pitch="${escapeHtml(row.registry_code)}">Kopeeri kõnespikker</button>
          </section>

          <details class="crm-sheet-section">
            <summary>Sisemine link</summary>
            <p class="crm-sheet-note">See on sisemine firma tööleht CRM-is. Avaliku personaalse maandumislehe teeme hiljem ainult siis, kui andmed ja pakkumine on kontrollitud.</p>
            <code>${escapeHtml(sheetUrl)}</code>
          </details>

          <div class="crm-row-actions crm-sheet-actions">${renderCardActions(row, false)}</div>
        `;
      };

      const openDetail = (registryCode, updateHash = true) => {
        state.selectedRegistryCode = registryCode;
        renderDetail(registryCode);
        renderBoard();

        if (updateHash) {
          const url = new URL(window.location.href);
          url.hash = `firma=${encodeURIComponent(registryCode)}`;
          window.history.replaceState(null, "", url.toString());
        }
      };

      const closeDetail = () => {
        state.selectedRegistryCode = null;
        detailPanel.hidden = true;
        detailContent.innerHTML = "";
        renderBoard();

        if (window.location.hash.startsWith("#firma=")) {
          window.history.replaceState(null, "", window.location.pathname);
        }
      };

      const renderBoard = () => {
        const rows = filteredRows();
        renderMetrics();
        emptyState.hidden = rows.length > 0;

        kanbanBoard.innerHTML = kanbanColumns.map((column) => {
          const columnRows = rows.filter(column.matches);
          const cards = columnRows.length
            ? columnRows.map(renderCompanyCard).join("")
            : `<div class="crm-column-empty">Praegu tühi.</div>`;

          return `
            <section class="crm-kanban-column" data-column="${column.id}">
              <header>
                <div>
                  <h2>${escapeHtml(column.title)}</h2>
                  <p>${escapeHtml(column.hint)}</p>
                </div>
                <b>${columnRows.length}</b>
              </header>
              <div class="crm-kanban-cards">${cards}</div>
            </section>
          `;
        }).join("");

        if (state.selectedRegistryCode) {
          renderDetail(state.selectedRegistryCode);
        }
      };

      const loadBoard = async () => {
        if (!supabase) {
          setMessage(boardMessage, "Supabase anon key puudub. Lisa Vercelis PUBLIC_SUPABASE_ANON_KEY.", "error");
          return;
        }

        setMessage(boardMessage, "Laen ettevõtteid ja müügisignaale...", "");
        await loadCriteriaAndStats();

        const { data, error } = await supabase.rpc("crm_get_company_lead_universe", {
          p_limit: 1000,
          p_min_score: 0
        });

        if (error) {
          setMessage(boardMessage, `CRM andmete laadimine ei õnnestunud: ${error.message}`, "error");
          state.rows = [];
          renderBoard();
          return;
        }

        state.rows = Array.isArray(data) ? data : [];
        setMessage(boardMessage, state.rows.length ? "Andmed laetud." : "Andmeid pole veel või kasutajal puudub ligipääs.", state.rows.length ? "ok" : "");
        if (!state.selectedRegistryCode && window.location.hash.startsWith("#firma=")) {
          state.selectedRegistryCode = decodeURIComponent(window.location.hash.replace("#firma=", ""));
        }
        renderBoard();
      };

      const promoteCompany = async (registryCode) => {
        setMessage(boardMessage, "Lisan ettevõtte müügitöösse...", "");
        const { error } = await supabase.rpc("crm_promote_company_to_prospect", {
          p_registry_code: registryCode
        });

        if (error) {
          setMessage(boardMessage, `Ettevõtet ei saanud müüki lisada: ${error.message}`, "error");
          return;
        }

        setMessage(boardMessage, "Ettevõte lisatud müüki.", "ok");
        await loadBoard();
      };

      const queueVtaCheck = async (registryCode) => {
        setMessage(boardMessage, "Käivitan selle firma VTA kontrolli taustal...", "");
        const { error } = await supabase.rpc("crm_queue_vta_check", {
          p_registry_code: registryCode
        });

        if (error) {
          setMessage(boardMessage, `VTA kontrolli ei saanud käivitada: ${error.message}`, "error");
          return;
        }

        setMessage(boardMessage, "VTA kontroll käivitatud. Tulemus ilmub siia, kui taustatöö lõpetab.", "ok");
        await loadBoard();
      };

      const queueTopVtaChecks = async () => {
        setMessage(boardMessage, "Käivitan 10 tugeva firma VTA kontrolli taustal...", "");
        queueTopVtaButton.disabled = true;

        const { data, error } = await supabase.rpc("crm_queue_next_vta_checks", {
          p_limit: 10,
          p_min_score: 75
        });

        queueTopVtaButton.disabled = false;

        if (error) {
          setMessage(boardMessage, `VTA kontrolle ei saanud käivitada: ${error.message}`, "error");
          return;
        }

        const added = Array.isArray(data) ? data.length : 0;
        setMessage(boardMessage, added ? `${added} firmat läks VTA taustakontrolli.` : "Uusi sobivaid VTA kontrolle ei olnud lisada.", added ? "ok" : "");
        await loadBoard();
      };

      const updateStatus = async (prospectId, status) => {
        const note = window.prompt("Lühike märkus järgmisele sammule:", "") || "";
        const { error } = await supabase.rpc("crm_update_prospect_status", {
          p_prospect_id: prospectId,
          p_crm_status: status,
          p_note: note,
          p_next_follow_up_at: null
        });

        if (error) {
          setMessage(boardMessage, `Staatuse muutmine ei õnnestunud: ${error.message}`, "error");
          return;
        }

        setMessage(boardMessage, "Staatus uuendatud.", "ok");
        await loadBoard();
      };

      const copyPitch = async (registryCode) => {
        const row = findRow(registryCode);
        if (!row) return;

        const text = [
          row.company_name,
          row.registry_code,
          "",
          row.recommended_pitch,
          "",
          `Sisemine tööleht: ${window.location.origin}/crm/#firma=${row.registry_code}`
        ].join("\n");

        try {
          await navigator.clipboard.writeText(text);
          setMessage(boardMessage, "Kõnespikker kopeeritud.", "ok");
        } catch (_error) {
          setMessage(boardMessage, text, "");
        }
      };

      const handleCrmAction = async (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (!target) return;

        const closeButton = target.closest("[data-close-detail]");
        if (closeButton) {
          closeDetail();
          return;
        }

        const detailButton = target.closest("[data-detail-code]");
        if (detailButton) {
          openDetail(detailButton.getAttribute("data-detail-code"));
          return;
        }

        const vtaButton = target.closest("[data-vta-code]");
        if (vtaButton) {
          await queueVtaCheck(vtaButton.getAttribute("data-vta-code"));
          return;
        }

        const copyButton = target.closest("[data-copy-pitch]");
        if (copyButton) {
          await copyPitch(copyButton.getAttribute("data-copy-pitch"));
          return;
        }

        const statusButton = target.closest("[data-status-action]");
        if (statusButton) {
          await updateStatus(statusButton.getAttribute("data-prospect-id"), statusButton.getAttribute("data-status-action"));
          return;
        }

        const promoteButton = target.closest("[data-promote-code]");
        if (promoteButton) {
          await promoteCompany(promoteButton.getAttribute("data-promote-code"));
        }
      };

      const boot = async () => {
        if (!supabase) {
          showLogin();
          setMessage(loginMessage, "Supabase anon key puudub. Lisa Vercelis PUBLIC_SUPABASE_ANON_KEY.", "error");
          return;
        }

        const { data } = await supabase.auth.getSession();
        state.session = data.session;

        if (!state.session) {
          showLogin();
          return;
        }

        userEmail.textContent = state.session.user?.email || "";
        showApp();
        await loadCurrentUser();
        await loadBoard();
        await loadUsers();
      };

      loginForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!supabase) return;

        const email = new FormData(loginForm).get("email");
        setMessage(loginMessage, "Saadan sisselogimise lingi...", "");

        const { error } = await supabase.auth.signInWithOtp({
          email,
          options: {
            emailRedirectTo: crmRedirectUrl()
          }
        });

        if (error) {
          setMessage(loginMessage, `Sisselogimise linki ei saanud saata: ${error.message}`, "error");
          return;
        }

        setMessage(loginMessage, "Link saadetud. Kontrollige e-maili ja vajutage lingile.", "ok");
      });

      signOutButton.addEventListener("click", async () => {
        await supabase.auth.signOut();
        state.session = null;
        state.currentUser = null;
        state.rows = [];
        state.users = [];
        showLogin();
      });

      refreshButton.addEventListener("click", loadBoard);
      queueTopVtaButton.addEventListener("click", queueTopVtaChecks);
      viewFilter.addEventListener("click", (event) => {
        const button = event.target instanceof Element
          ? event.target.closest("[data-view]")
          : null;
        if (!button) return;

        state.view = button.getAttribute("data-view") || "strong";
        viewFilter.querySelectorAll("[data-view]").forEach((item) => {
          item.classList.toggle("is-active", item === button);
        });
        renderBoard();
      });
      usersRefreshButton.addEventListener("click", loadUsers);
      userForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        await addUser(userForm);
      });
      [searchInput, statusFilter, vtaFilter, scoreFilter].forEach((input) => {
        input.addEventListener("input", renderBoard);
        input.addEventListener("change", renderBoard);
      });

      kanbanBoard.addEventListener("click", handleCrmAction);
      detailPanel.addEventListener("click", handleCrmAction);

      usersList.addEventListener("click", async (event) => {
        const button = event.target instanceof Element
          ? event.target.closest("[data-user-active-toggle]")
          : null;
        if (!button) return;
        await setUserActive(
          button.getAttribute("data-user-active-toggle"),
          button.getAttribute("data-next-active") === "true"
        );
      });

      supabase?.auth.onAuthStateChange((_event, session) => {
        state.session = session;
      });

      boot();
    </script>

    <style>
      .crm-page {
        min-height: 100vh;
        background: #eef6f8;
      }

      .crm-shell {
        width: min(1480px, calc(100% - 28px));
        margin: 0 auto;
        padding: 28px 0 44px;
      }

      .crm-panel,
      .crm-app {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--white);
        box-shadow: var(--shadow);
      }

      .crm-login {
        max-width: 760px;
        margin: 12vh auto 0;
        padding: 32px;
      }

      .crm-login h1,
      .crm-header h1 {
        margin-top: 10px;
        color: var(--navy);
      }

      .crm-login p,
      .crm-header p {
        color: var(--muted);
      }

      .crm-login-form {
        display: grid;
        gap: 10px;
        margin-top: 24px;
      }

      .crm-login-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
      }

      .crm-login input,
      .crm-filters input,
      .crm-filters select {
        width: 100%;
        min-height: 48px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 10px 12px;
        color: var(--ink);
        background: var(--white);
      }

      .crm-note {
        margin-top: 22px;
        border-left: 4px solid var(--accent);
        border-radius: 8px;
        padding: 14px;
        background: #fff9ea;
        color: var(--muted);
      }

      .crm-app {
        padding: 22px;
      }

      .crm-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        align-items: start;
      }

      .crm-user-box {
        display: grid;
        gap: 10px;
        justify-items: end;
        color: var(--muted);
        font-weight: 800;
      }

      .crm-metrics {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 10px;
        margin: 22px 0;
      }

      .crm-metrics article {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 14px;
        background: var(--paper);
      }

      .crm-metrics strong {
        display: block;
        color: var(--teal);
        font-size: 1.7rem;
        line-height: 1;
      }

      .crm-metrics span {
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 800;
      }

      .crm-score-model {
        padding: 0;
        margin-bottom: 16px;
        box-shadow: none;
        background: #f7fbfb;
      }

      .crm-score-model summary {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px;
        align-items: center;
        padding: 14px 18px;
        cursor: pointer;
        list-style: none;
      }

      .crm-score-model summary::-webkit-details-marker {
        display: none;
      }

      .crm-score-model summary::after {
        content: "+";
        display: inline-grid;
        width: 30px;
        height: 30px;
        place-items: center;
        border-radius: 999px;
        background: var(--white);
        color: var(--navy);
        font-weight: 900;
      }

      .crm-score-model[open] summary::after {
        content: "−";
      }

      .crm-score-model summary strong,
      .crm-score-model summary em {
        display: block;
      }

      .crm-score-model summary strong {
        color: var(--navy);
      }

      .crm-score-model summary em {
        margin-top: 2px;
        color: var(--muted);
        font-size: 0.9rem;
        font-style: normal;
        font-weight: 800;
      }

      .crm-score-model-body {
        display: grid;
        gap: 14px;
        padding: 0 18px 18px;
      }

      .crm-score-model h2 {
        margin: 6px 0 0;
        color: var(--navy);
        font-size: 1.55rem;
      }

      .crm-score-model p {
        margin: 8px 0 0;
        color: var(--muted);
      }

      .crm-criteria-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
      }

      .crm-criteria-grid article {
        display: grid;
        gap: 8px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 12px;
        background: var(--white);
      }

      .crm-criteria-grid strong {
        color: var(--navy);
      }

      .crm-criteria-grid strong b {
        color: var(--teal);
        white-space: nowrap;
      }

      .crm-criteria-grid span,
      .crm-criteria-grid em {
        color: var(--muted);
        font-size: 0.86rem;
        font-style: normal;
      }

      .crm-score-note {
        border-left: 4px solid var(--teal);
        border-radius: 8px;
        padding: 10px 12px;
        background: var(--white);
        font-weight: 750;
      }

      .crm-admin {
        padding: 18px;
        margin-bottom: 16px;
        box-shadow: none;
        background: #fff9ea;
      }

      .crm-admin-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px;
        align-items: start;
      }

      .crm-admin h2 {
        margin-top: 6px;
        color: var(--navy);
        font-size: 1.6rem;
      }

      .crm-admin p {
        margin: 6px 0 0;
        color: var(--muted);
      }

      .crm-user-form {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(130px, 0.28fr) auto;
        gap: 12px;
        align-items: end;
        margin-top: 16px;
      }

      .crm-user-form label {
        display: grid;
        gap: 6px;
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 850;
      }

      .crm-user-form input,
      .crm-user-form select {
        width: 100%;
        min-height: 48px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 10px 12px;
        color: var(--ink);
        background: var(--white);
      }

      .crm-users-list {
        display: grid;
        gap: 8px;
        margin-top: 14px;
      }

      .crm-user-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
        border: 1px solid rgba(214, 166, 66, 0.4);
        border-radius: 8px;
        padding: 10px 12px;
        background: var(--white);
      }

      .crm-user-row strong,
      .crm-user-row span {
        display: block;
      }

      .crm-user-row span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .crm-user-row button {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 8px 10px;
        background: var(--white);
        color: var(--navy);
        cursor: pointer;
        font-size: 0.86rem;
        font-weight: 850;
      }

      .crm-user-row button:disabled {
        cursor: not-allowed;
        opacity: 0.55;
      }

      .crm-view-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 12px;
      }

      .crm-view-tabs button {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 9px 12px;
        background: var(--white);
        color: var(--navy);
        cursor: pointer;
        font-weight: 850;
      }

      .crm-view-tabs button.is-active {
        border-color: var(--teal);
        background: var(--teal);
        color: var(--white);
      }

      .crm-filters {
        display: grid;
        grid-template-columns: minmax(240px, 1.4fr) minmax(140px, 0.7fr) minmax(140px, 0.7fr) minmax(110px, 0.45fr) auto auto;
        gap: 12px;
        align-items: end;
        padding: 14px;
        margin-bottom: 16px;
        box-shadow: none;
      }

      .crm-filters label {
        display: grid;
        gap: 6px;
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 850;
      }

      .crm-refresh {
        color: var(--white);
        background: var(--navy);
      }

      .crm-workspace {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, 0.42fr);
        gap: 16px;
        align-items: start;
      }

      .crm-kanban {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .crm-kanban-column {
        display: grid;
        gap: 12px;
        align-content: start;
        min-height: 320px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 12px;
        background: #f7fbfb;
      }

      .crm-kanban-column > header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: start;
        min-height: 48px;
      }

      .crm-kanban-column h2 {
        margin: 0;
        color: var(--navy);
        font-size: 1.05rem;
      }

      .crm-kanban-column p {
        margin: 3px 0 0;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 750;
      }

      .crm-kanban-column > header b {
        display: inline-grid;
        min-width: 32px;
        min-height: 32px;
        place-items: center;
        border-radius: 999px;
        background: var(--navy);
        color: var(--white);
        font-size: 0.86rem;
      }

      .crm-kanban-cards {
        display: grid;
        gap: 10px;
      }

      .crm-column-empty {
        border: 1px dashed var(--line);
        border-radius: 8px;
        padding: 16px;
        color: var(--muted);
        background: var(--white);
        font-size: 0.9rem;
        font-weight: 750;
      }

      .crm-lead-card {
        display: grid;
        gap: 8px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 10px;
        background: var(--white);
      }

      .crm-lead-card.crm-signal-strong {
        border-left: 5px solid var(--teal);
      }

      .crm-lead-card.crm-signal-medium {
        border-left: 5px solid var(--accent);
      }

      .crm-lead-card.crm-signal-low {
        border-left: 5px solid var(--line);
      }

      .crm-lead-card.is-selected {
        border-color: var(--teal);
        box-shadow: 0 0 0 3px rgba(0, 155, 141, 0.12);
      }

      .crm-lead-card header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: start;
      }

      .crm-lead-card strong,
      .crm-lead-card span {
        display: block;
      }

      .crm-lead-card header strong,
      .crm-card-title {
        color: var(--navy);
        line-height: 1.2;
      }

      .crm-lead-card header span,
      .crm-vta-mini span {
        color: var(--muted);
        font-size: 0.84rem;
        font-weight: 750;
      }

      .crm-lead-card header b {
        display: inline-grid;
        min-width: 40px;
        min-height: 40px;
        place-items: center;
        border-radius: 8px;
        background: var(--teal);
        color: var(--white);
        font-size: 1.1rem;
      }

      .crm-signal-line {
        display: grid;
        gap: 3px;
        border-radius: 8px;
        padding: 8px;
        background: #f7fbfb;
      }

      .crm-signal-line span {
        color: var(--teal);
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
      }

      .crm-signal-line strong {
        color: var(--navy);
        font-size: 0.9rem;
        line-height: 1.3;
      }

      .crm-signal-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .crm-signal-chips span {
        display: inline-flex;
        border-radius: 999px;
        padding: 5px 8px;
        background: var(--ice);
        color: var(--navy);
        font-size: 0.78rem;
        font-weight: 900;
      }

      .crm-vta-mini {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
        border-radius: 8px;
        padding: 8px 10px;
        background: #fff9ea;
      }

      .crm-vta-mini[data-vta-state="good"],
      .crm-vta-mini[data-vta-state="checked"] {
        background: var(--ice);
      }

      .crm-vta-mini[data-vta-state="risk"] {
        background: #fff1ed;
      }

      .crm-vta-mini[data-vta-state="running"] {
        background: #eef6f8;
      }

      .crm-vta-mini strong {
        color: var(--navy);
        font-size: 0.9rem;
      }

      .crm-company-sheet {
        position: sticky;
        top: 12px;
        display: grid;
        gap: 16px;
        padding: 18px;
        box-shadow: none;
      }

      .crm-sheet-empty {
        color: var(--muted);
        font-weight: 750;
      }

      .crm-company-sheet[hidden] {
        display: none;
      }

      .crm-sheet-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: start;
      }

      .crm-sheet-head h2 {
        margin: 6px 0 0;
        color: var(--navy);
        font-size: 1.45rem;
        line-height: 1.15;
      }

      .crm-sheet-head p,
      .crm-company-sheet h3 {
        margin: 4px 0 0;
      }

      .crm-sheet-head p,
      .crm-sheet-note {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .crm-sheet-close {
        width: 36px;
        height: 36px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--white);
        color: var(--navy);
        cursor: pointer;
        font-size: 1.35rem;
        line-height: 1;
      }

      .crm-sheet-score {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 10px;
        align-items: center;
        border-radius: 8px;
        padding: 12px;
        background: var(--ice);
      }

      .crm-sheet-score strong {
        color: var(--teal);
        font-size: 1.8rem;
        line-height: 1;
      }

      .crm-sheet-score span {
        color: var(--navy);
        font-weight: 850;
      }

      .crm-company-sheet section,
      .crm-sheet-section {
        display: grid;
        gap: 10px;
        border-top: 1px solid var(--line);
        padding-top: 14px;
      }

      .crm-company-sheet h3,
      .crm-sheet-section summary {
        color: var(--navy);
        font-size: 0.98rem;
      }

      .crm-sheet-section summary {
        cursor: pointer;
        font-weight: 900;
      }

      .crm-sheet-list {
        display: grid;
        gap: 8px;
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .crm-sheet-list li {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: start;
        border-bottom: 1px solid #eef2f2;
        padding-bottom: 8px;
      }

      .crm-sheet-list span {
        color: var(--muted);
        font-size: 0.88rem;
      }

      .crm-sheet-list strong {
        color: var(--navy);
        text-align: right;
      }

      .crm-pitch {
        margin: 0;
        border-radius: 8px;
        padding: 12px;
        background: #f7fbfb;
        color: var(--ink);
        line-height: 1.5;
      }

      .crm-company-sheet code {
        display: block;
        overflow-wrap: anywhere;
        border-radius: 8px;
        padding: 10px;
        background: #f3f4f6;
        color: var(--navy);
        font-size: 0.82rem;
      }

      .crm-sheet-actions {
        border-top: 1px solid var(--line);
        padding-top: 14px;
      }

      .crm-board-status {
        margin-top: 16px;
        padding: 10px 14px;
        box-shadow: none;
      }

      .crm-table-wrap {
        width: 100%;
        overflow-x: auto;
      }

      .crm-table {
        width: 100%;
        min-width: 1180px;
        border-collapse: collapse;
      }

      .crm-table th,
      .crm-table td {
        border-bottom: 1px solid var(--line);
        padding: 12px;
        text-align: left;
        vertical-align: top;
      }

      .crm-table th {
        color: var(--muted);
        font-size: 0.8rem;
        text-transform: uppercase;
      }

      .crm-table td > strong,
      .crm-table td > span {
        display: block;
      }

      .crm-table td > span,
      .crm-table td span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .crm-table small {
        display: block;
        margin-top: 6px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 800;
      }

      .crm-tags,
      .crm-row-actions,
      .crm-score-breakdown {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .crm-tags span,
      .crm-score-breakdown span,
      .crm-status {
        display: inline-flex;
        border-radius: 999px;
        padding: 5px 8px;
        background: var(--ice);
        color: var(--navy);
        font-size: 0.78rem;
        font-weight: 850;
      }

      .crm-score-breakdown {
        margin-top: 8px;
      }

      .crm-score-breakdown span {
        background: #f4f7f7;
        color: var(--muted);
      }

      .crm-row-actions button {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 7px 9px;
        background: var(--white);
        color: var(--navy);
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 850;
      }

      .crm-row-actions .crm-action-primary {
        border-color: var(--teal);
        background: var(--teal);
        color: var(--white);
      }

      .crm-row-actions .crm-action-secondary {
        background: #f7fbfb;
      }

      .crm-row-actions button:disabled {
        cursor: not-allowed;
        opacity: 0.68;
      }

      .crm-row-actions button:hover {
        border-color: var(--teal);
        color: var(--teal);
      }

      .crm-row-actions .crm-action-primary:hover {
        color: var(--white);
      }

      .crm-empty {
        padding: 20px;
        color: var(--muted);
      }

      .crm-message {
        min-height: 24px;
        color: var(--muted);
      }

      .crm-message[data-type="ok"] {
        color: var(--teal);
        font-weight: 850;
      }

      .crm-message[data-type="error"] {
        color: #a33a22;
        font-weight: 850;
      }

      @media (max-width: 900px) {
        .crm-header,
        .crm-login-row {
          grid-template-columns: 1fr;
        }

        .crm-user-box {
          justify-items: start;
        }

        .crm-metrics,
        .crm-criteria-grid,
        .crm-admin-head,
        .crm-user-form,
        .crm-filters,
        .crm-workspace,
        .crm-kanban {
          grid-template-columns: 1fr;
        }

        .crm-company-sheet {
          position: static;
        }
      }
    </style>
  </body>
</html>
