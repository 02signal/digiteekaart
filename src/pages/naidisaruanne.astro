---
import "../styles/global.css";

const checkedAt = "30.05.2026";
const roadmapUrl = "https://eis.ee/teenused/digitaliseerimise-teekaardi-toetus/";
const roadmapDevelopmentUrl = "https://eis.ee/teenused/digitaliseerimise-teekaardi-arendustegevused-toetus/";
const rteSoftwareUrl = "https://eis.ee/teenused/rte_tarkvara_toetus/";
const rteAutomationUrl = "https://eis.ee/teenused/rte_automatiseerimise_toetus/";
const vtaUrl = "https://fin.ee/riigihanked-riigiabi-osalused/riigiabi/vahese-tahtsusega-abi";
const businessRegisterUrl = "https://ariregister.rik.ee/est/company/14127891/Ettev%C3%B5tluskeskus-O%C3%9C";
const emailHref = "mailto:info@02signal.ai?subject=Digiteekaart.ee%20-%20Ettev%C3%B5tluskeskus%20O%C3%9C%20n%C3%A4idisaruanne";

const schema = {
  "@context": "https://schema.org",
  "@type": "Report",
  name: "Digiteekaardi eelhinnangu näidis: Ettevõtluskeskus OÜ",
  inLanguage: "et",
  about: "EIS digitaliseerimise teekaardi toetuse eelhindamine",
  provider: {
    "@type": "Organization",
    name: "Ettevõtluskeskus OÜ",
    url: "https://digiteekaart.ee/"
  },
  dateModified: "2026-05-30"
};
---

<!doctype html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Näidisaruanne | Ettevõtluskeskus OÜ digiteekaardi eelhinnang</title>
    <meta
      name="description"
      content="Klikitav näidisaruanne: kuidas Digiteekaart.ee hindab ettevõtte sobivust EIS digitaliseerimise teekaardi ja seotud avatud meetmete jaoks."
    />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="https://digiteekaart.ee/naidisaruanne/" />
    <meta property="og:title" content="Näidisaruanne: Ettevõtluskeskus OÜ digiteekaardi eelhinnang" />
    <meta
      property="og:description"
      content="Lihtne näide, mida ettevõtte omanik saab pärast eelhindamist: sobivuse kontroll, riskid ja järgmine praktiline samm."
    />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://digiteekaart.ee/naidisaruanne/" />
    <meta property="og:image" content="https://digiteekaart.ee/naidisaruande-eelvaade.svg" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="topbar">
      <nav class="nav" aria-label="Põhinavigeerimine">
        <a class="brand" href="/">Digiteekaart.ee</a>
        <div class="navlinks">
          <a href="/">Avaleht</a>
          <a href="/#eelhindamine">Eelhindamine</a>
          <a href="/privaatsus/">Privaatsus</a>
          <a href="tel:+37258180435">+372 5818 0435</a>
        </div>
      </nav>
    </header>

    <main class="report-page">
      <section class="report-hero">
        <div class="section-inner">
          <span class="eyebrow">Näidisaruanne ettevõtte omanikule</span>
          <h1>Ettevõtluskeskus OÜ: kas digiteekaardi toetus võiks sobida?</h1>
          <p>
            See on näidis sellest, mida anname pärast esmast kontrolli. See ei ole EIS-i otsus
            ega toetusgarantii. See aitab omanikul näha, kas edasi liikumine on mõistlik.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="/#eelhindamine">Soovin oma ettevõtte eelhinnangut</a>
            <a class="btn btn-secondary" href="tel:+37258180435">Helista +372 5818 0435</a>
          </div>
          <p class="report-date">Allikad kontrollitud: {checkedAt}</p>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Kiire otsus</span>
            <h2>Esimene vaade: teekaardi toetus on realistlik esimene samm.</h2>
            <p>
              Avalike andmete ja näidise sisendi põhjal ületab Ettevõtluskeskus OÜ peamise
              müügitulu kontrolli. Enne päris taotlust tuleb üle kontrollida VTA jääk,
              maksuvõlg, varasem digidiagnostika toetus ja lõplik tegevusala sobivus.
            </p>
          </div>

          <div class="summary-panel">
            <div>
              <span class="status-tag status-green">Tõenäoline esimene samm</span>
              <h3>Digitaliseerimise teekaardi toetus</h3>
              <p>
                EIS-i lehel on meede avatud, suurim toetus on kuni 10 000 eurot ja
                omafinantseering 30-50%. Meie soovitus oleks alustada sellest, sest see loob
                ametliku 3 aasta plaani ja annab aluse järgmisteks arendusteks.
              </p>
            </div>
            <div class="score-box">
              <strong>Esialgne hinnang</strong>
              <span>Jah, tasub kontroll lõpuni teha</span>
            </div>
          </div>
        </div>
      </section>

      <section class="ice">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Ettevõtte andmed</span>
            <h2>Mida näidises kontrollisime.</h2>
          </div>

          <div class="assessment-grid">
            <article class="card">
              <span class="status-tag status-blue">Avalik register</span>
              <h3>Ettevõte</h3>
              <p><strong>Ettevõtluskeskus OÜ</strong></p>
              <p>Registrikood: 14127891</p>
              <p>Põhitegevusala: 85599 - muu mujal liigitamata õpe.</p>
            </article>
            <article class="card">
              <span class="status-tag status-green">Müügitulu kontroll läbitud</span>
              <h3>Kahe aasta müügitulu</h3>
              <p>2023: 548 861 eurot</p>
              <p>2024: 331 542 eurot</p>
              <p>Keskmine: umbes 440 201 eurot. See on üle EIS-i 200 000 euro piiri.</p>
            </article>
            <article class="card">
              <span class="status-tag status-amber">Vajab ametlikku ülevaatust</span>
              <h3>VTA jääk</h3>
              <p>
                Näidise sisend: VTA-d ei ole kasutatud. Kui see kinnitub RAR-is, on ruumi
                kuni 300 000 euro piirmäärani.
              </p>
              <p>Enne päris pakkumist kontrollime VTA jäägi üle.</p>
            </article>
          </div>

          <p class="notice">
            Kasutatud avalik info: <a href={businessRegisterUrl} target="_blank" rel="noreferrer">e-äriregister</a>
            ja <a href={vtaUrl} target="_blank" rel="noreferrer">Rahandusministeeriumi VTA selgitus</a>.
          </p>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Avatud võimalused</span>
            <h2>Milliseid EIS meetmeid näidise põhjal vaataksime.</h2>
            <p>
              Siin on ainult need rajad, mille puhul EIS-i lehel oli kontrolli hetkel staatus
              "Avatud" ja mille seos ettevõtte digitaliseerimisega on piisavalt selge.
            </p>
          </div>

          <div class="measure-list">
            <article class="measure-card">
              <div>
                <span class="status-tag status-green">1. samm</span>
                <h3>Digitaliseerimise teekaardi toetus</h3>
                <p>
                  Sobib selleks, et kaardistada tööprotsessid, andmed, süsteemid,
                  küberturvalisuse esmane tase ja koostada 3 aasta tegevusplaan.
                </p>
              </div>
              <dl>
                <div><dt>Suurim toetus</dt><dd>10 000 eurot</dd></div>
                <div><dt>Omafinantseering</dt><dd>30-50%</dd></div>
                <div><dt>Peamine kontroll</dt><dd>keskmine müügitulu vähemalt 200 000 eurot</dd></div>
              </dl>
              <a href={roadmapUrl} target="_blank" rel="noreferrer">EIS allikas</a>
            </article>

            <article class="measure-card">
              <div>
                <span class="status-tag status-blue">Pärast teekaarti</span>
                <h3>Teekaardi nõustamis- ja arendustegevuste toetus</h3>
                <p>
                  Sobib siis, kui teekaart on olemas ja selles kirjeldatud arendused tuleb
                  päriselt ellu viia. Ilma teekaardita ei oleks see esimene samm.
                </p>
              </div>
              <dl>
                <div><dt>Suurim toetus</dt><dd>35 000 eurot</dd></div>
                <div><dt>Omafinantseering</dt><dd>30-50%</dd></div>
                <div><dt>Peamine kontroll</dt><dd>teekaart peab olema olemas ja ajakohane</dd></div>
              </dl>
              <a href={roadmapDevelopmentUrl} target="_blank" rel="noreferrer">EIS allikas</a>
            </article>

            <article class="measure-card">
              <div>
                <span class="status-tag status-blue">Väike praktiline projekt</span>
                <h3>RTE tarkvara kasutusele võtmise või liidestamise toetus</h3>
                <p>
                  Võib sobida lihtsaks tööks: uue tarkvara kasutuselevõtt või olemasolevate
                  süsteemide liidestamine, näiteks CRM, vorm, andmebaas ja automaatne teavitus.
                </p>
              </div>
              <dl>
                <div><dt>Toetus</dt><dd>2 000-5 000 eurot</dd></div>
                <div><dt>Omafinantseering</dt><dd>50%</dd></div>
                <div><dt>Peamine kontroll</dt><dd>keskmine müügitulu vähemalt 50 000 eurot</dd></div>
              </dl>
              <a href={rteSoftwareUrl} target="_blank" rel="noreferrer">EIS allikas</a>
            </article>

            <article class="measure-card">
              <div>
                <span class="status-tag status-amber">Suurem järgmine projekt</span>
                <h3>RTE äriprotsesside automatiseerimise ja andmevahetuse toetus</h3>
                <p>
                  Võib sobida hiljem, kui teekaart või samaväärne strateegia on olemas ja
                  projekt paneb süsteemid päriselt andmeid automaatselt vahetama.
                </p>
              </div>
              <dl>
                <div><dt>Suurim toetus</dt><dd>150 000 eurot</dd></div>
                <div><dt>Omafinantseering</dt><dd>50%</dd></div>
                <div><dt>Peamine kontroll</dt><dd>partner või koostööpartner peab olema kaasatud</dd></div>
              </dl>
              <a href={rteAutomationUrl} target="_blank" rel="noreferrer">EIS allikas</a>
            </article>
          </div>
        </div>
      </section>

      <section class="ice">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Soovitus Ettevõtluskeskus OÜ-le</span>
            <h2>Mida selle näidise põhjal praktiliselt teha.</h2>
          </div>

          <div class="recommendation-flow">
            <article>
              <strong>01</strong>
              <h3>Tee ametlik sobivuse kontroll lõpuni</h3>
              <p>
                Kontrollida VTA jääk, maksuvõlg, varasem digidiagnostika toetus ja tegevusala
                välistused. Kui need on korras, on teekaardi töö mõistlik järgmine samm.
              </p>
            </article>
            <article>
              <strong>02</strong>
              <h3>Koosta teekaart ühe konkreetse väärtusahela ümber</h3>
              <p>
                Näiteks: päring tuleb veebist, ettevõtte andmed leitakse registrist, sobivus
                hinnatakse, kokkuvõte läheb omanikule ja meeskond näeb järgmisi samme.
              </p>
            </article>
            <article>
              <strong>03</strong>
              <h3>Vali pärast teekaarti õige jätkumeede</h3>
              <p>
                Kui vaja on väike liidestus, vaadata RTE tarkvara toetust. Kui tekib suurem
                andmevahetuse ja automatiseerimise projekt, vaadata RTE automatiseerimise toetust.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="section-head">
            <span class="kicker">Aus piir</span>
            <h2>Mida see näidis ei väida.</h2>
          </div>
          <div class="grid-2">
            <article class="card">
              <h3>See ei ole EIS-i otsus</h3>
              <p>
                Lõpliku otsuse teeb EIS/RTK ametliku taotluse, dokumentide ja hindamise põhjal.
                Meie roll on aidata omanikul enne kulutamist aru saada, kas tee on mõistlik.
              </p>
            </article>
            <article class="card">
              <h3>Me ei näita ebakindlaid meetmeid sobivana</h3>
              <p>
                Kui meede on liiga eritingimuslik või sobivus ei ole näidise põhjal selge,
                jätame selle soovitusest välja. Nii väldime müügilubadusi, mis hiljem aega raiskavad.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="navy">
        <div class="section-inner contact">
          <div>
            <span class="kicker">Järgmine samm</span>
            <h2>Soovite sama kontrolli oma ettevõttele?</h2>
            <p>
              Saatke ettevõtte nimi ja registrikood. Kontrollime esmased tingimused ning ütleme,
              kas digiteekaardiga tasub edasi liikuda.
            </p>
            <div class="inline-actions">
              <a class="btn btn-primary" href="/#eelhindamine">Tee eelhindamine</a>
              <a class="btn btn-secondary" href="tel:+37258180435">Helista +372 5818 0435</a>
            </div>
          </div>
          <aside class="contact-card">
            <h3>Kontakt</h3>
            <p>Ettevõtluskeskus OÜ / 02Signal</p>
            <p><a href={emailHref}>info@02signal.ai</a></p>
            <p><a href="tel:+37258180435">+372 5818 0435</a></p>
          </aside>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <strong>Digiteekaart.ee</strong>
        <span>Ettevõtluskeskus OÜ · näidisaruanne · <a href="/privaatsus/">Privaatsus</a></span>
      </div>
    </footer>
  </body>
</html>
