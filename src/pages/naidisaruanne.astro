---
import "../styles/global.css";

const checkedAt = "30.05.2026";
const roadmapUrl = "https://eis.ee/teenused/digitaliseerimise-teekaardi-toetus/";
const roadmapDevelopmentUrl = "https://eis.ee/teenused/digitaliseerimise-teekaardi-arendustegevused-toetus/";
const rteSoftwareUrl = "https://eis.ee/teenused/rte_tarkvara_toetus/";
const rteAutomationUrl = "https://eis.ee/teenused/rte_automatiseerimise_toetus/";
const vtaUrl = "https://fin.ee/riigihanked-riigiabi-osalused/riigiabi/vahese-tahtsusega-abi";
const businessRegisterUrl = "https://ariregister.rik.ee/est/company/14127891/Ettev%C3%B5tluskeskus-O%C3%9C";
const emailHref = "mailto:info@02signal.ai?subject=Digiteekaart.ee%20-%20Ettev%C3%B5tluskeskus%20O%C3%9C%20n%C3%A4idisaruanne";

const schema = {
  "@context": "https://schema.org",
  "@type": "Report",
  name: "Digiteekaardi eelhinnangu näidis: Ettevõtluskeskus OÜ",
  inLanguage: "et",
  about: "EIS digitaliseerimise teekaardi toetuse eelhindamine",
  provider: {
    "@type": "Organization",
    name: "Ettevõtluskeskus OÜ",
    url: "https://digiteekaart.ee/"
  },
  dateModified: "2026-05-30"
};
---

<!doctype html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Näidisaruanne | Ettevõtluskeskus OÜ digiteekaardi eelhinnang</title>
    <meta
      name="description"
      content="Klikitav näidisaruanne: kuidas Digiteekaart.ee hindab ettevõtte sobivust EIS digitaliseerimise teekaardi ja seotud avatud meetmete jaoks."
    />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="https://digiteekaart.ee/naidisaruanne/" />
    <meta property="og:title" content="Näidisaruanne: Ettevõtluskeskus OÜ digiteekaardi eelhinnang" />
    <meta
      property="og:description"
      content="Lihtne näide, mida ettevõtte omanik saab pärast eelhindamist: sobivuse kontroll, riskid ja järgmine praktiline samm."
    />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://digiteekaart.ee/naidisaruanne/" />
    <meta property="og:image" content="https://digiteekaart.ee/naidisaruande-eelvaade.svg" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="topbar">
      <nav class="nav" aria-label="Põhinavigeerimine">
        <a class="brand" href="/">Digiteekaart.ee</a>
        <div class="navlinks">
          <a href="/">Avaleht</a>
          <a href="/#eelhindamine">Eelhindamine</a>
          <a href="/privaatsus/">Privaatsus</a>
          <a href="tel:+37258180435">+372 5818 0435</a>
        </div>
      </nav>
    </header>

    <main class="report-page simple-report">
      <section class="report-hero simple-report-hero">
        <div class="section-inner">
          <span class="eyebrow">Näidisaruanne ettevõtte omanikule</span>
          <h1>Ettevõtluskeskus OÜ: tasub edasi kontrollida.</h1>
          <p>
            Lühike vastus: avalike andmete põhjal on digiteekaardi toetus realistlik esimene
            samm. Enne otsust tuleb kontrollida VTA jääk, maksuvõlg ja varasemad toetused.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="/#eelhindamine">Soovin sama kontrolli</a>
            <a class="btn btn-secondary" href="tel:+37258180435">Helista +372 5818 0435</a>
          </div>
          <p class="report-date">Allikad kontrollitud: {checkedAt}</p>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="owner-verdict">
            <div>
              <span class="status-tag status-green">Esialgne otsus</span>
              <h2>Jah, siin on mõtet edasi minna.</h2>
              <p>
                Ettevõtte müügitulu on piisav. Tegevusala ei paista esimesel vaatamisel välistatud.
                Kõige mõistlikum on teha lühike ametlik kontroll ja siis otsustada, kas koostada
                digiteekaart või minna väiksema tarkvara/liidestuse toetusega otse edasi.
              </p>
            </div>
            <aside class="owner-callout">
              <strong>Järgmine samm</strong>
              <span>15 minuti kõne + 4 kontrolli</span>
              <a href="tel:+37258180435">Helista kohe</a>
            </aside>
          </div>
        </div>
      </section>

      <section class="ice">
        <div class="section-inner">
          <div class="section-head compact-head">
            <span class="kicker">Mida omanik peab teadma</span>
            <h2>Kolm asja, mitte pikk raport.</h2>
          </div>

          <div class="simple-cards">
            <article>
              <strong>1</strong>
              <h3>Ettevõte ületab müügitulu piiri.</h3>
              <p>Kahe viimase aasta keskmine müügitulu on umbes 440 201 eurot.</p>
            </article>
            <article>
              <strong>2</strong>
              <h3>VTA tuleb ametlikult üle kontrollida.</h3>
              <p>Näidise sisend on 0 eurot kasutatud VTA-d, aga enne päris otsust kontrollime selle RAR-is.</p>
            </article>
            <article>
              <strong>3</strong>
              <h3>Väike tarkvara/liidestuse toetus võib sobida ka otse.</h3>
              <p>Digiteekaart ei ole RTE tarkvara toetuse eeltingimus, kui projekt on konkreetne.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="white">
        <div class="section-inner">
          <div class="section-head compact-head">
            <span class="kicker">Soovitus</span>
            <h2>Kuidas me edasi liiguksime.</h2>
          </div>

          <div class="owner-next-steps">
            <article>
              <span>01</span>
              <h3>Kontrollime 4 asja</h3>
              <p>VTA jääk, maksuvõlg, varasem digidiagnostika toetus ja tegevusala välistused.</p>
            </article>
            <article>
              <span>02</span>
              <h3>Valime õige tee</h3>
              <p>Kas teha digiteekaart või alustada väikse tarkvara/liidestuse toetusega.</p>
            </article>
            <article>
              <span>03</span>
              <h3>Paneme hinnaga plaani lauale</h3>
              <p>Mida teha, mis see maksab, mis osa võib olla toetatav ja mis osa jääb omafinantseeringuks.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="ice">
        <div class="section-inner narrow">
          <div class="section-head compact-head">
            <span class="kicker">Lisainfo</span>
            <h2>Täpsed andmed neile, kes tahavad kontrollida.</h2>
            <p>Alguses ei pea neid läbi lugema. Need on siin läbipaistvuse ja hilisema otsuse jaoks.</p>
          </div>

          <div class="report-details">
            <details>
              <summary>Milliseid ettevõtte andmeid vaatasime?</summary>
              <div class="detail-body">
                <p><strong>Ettevõtluskeskus OÜ</strong>, registrikood 14127891.</p>
                <p>Põhitegevusala: 85599 - muu mujal liigitamata õpe.</p>
                <p>2023 müügitulu: 548 861 eurot. 2024 müügitulu: 331 542 eurot.</p>
                <p>Kahe aasta keskmine: umbes 440 201 eurot.</p>
                <p><a href={businessRegisterUrl} target="_blank" rel="noreferrer">Vaata allikat e-äriregistris</a></p>
              </div>
            </details>

            <details>
              <summary>Millised toetused võivad olla asjakohased?</summary>
              <div class="detail-body">
                <ul class="check">
                  <li><strong>Digitaliseerimise teekaart:</strong> kuni 10 000 eurot, omafinantseering 30-50%, eeldab vähemalt 200 000 eurot kahe aasta keskmist müügitulu.</li>
                  <li><strong>Teekaardi arendustegevused:</strong> kuni 35 000 eurot, loogiline pärast ajakohast digiteekaarti.</li>
                  <li><strong>RTE tarkvara või liidestus:</strong> 2 000-5 000 eurot, omafinantseering 50%, digiteekaart ei ole eeltingimus.</li>
                  <li><strong>RTE automatiseerimine:</strong> kuni 150 000 eurot, suurem projekt, vajab selget partnerit ja andmevahetuse/automatiseerimise sisu.</li>
                </ul>
              </div>
            </details>

            <details>
              <summary>Mis võib otsust veel muuta?</summary>
              <div class="detail-body">
                <ul class="check">
                  <li>VTA jääk peab mahtuma 300 000 euro piiri sisse.</li>
                  <li>Maksuvõlg ei tohi olla takistuseks.</li>
                  <li>Varasem digidiagnostika või sama sisuga toetus võib välistada uue toetuse.</li>
                  <li>Lõplik tegevusala ja projekt peab sobima EIS tingimustega.</li>
                </ul>
                <p><a href={vtaUrl} target="_blank" rel="noreferrer">Vaata VTA selgitust</a></p>
              </div>
            </details>

            <details>
              <summary>Ametlikud EIS allikad</summary>
              <div class="detail-body source-list">
                <a href={roadmapUrl} target="_blank" rel="noreferrer">Digitaliseerimise teekaardi toetus</a>
                <a href={roadmapDevelopmentUrl} target="_blank" rel="noreferrer">Digiteekaardi nõustamis- ja arendustegevused</a>
                <a href={rteSoftwareUrl} target="_blank" rel="noreferrer">RTE tarkvara kasutusele võtmise või liidestamise toetus</a>
                <a href={rteAutomationUrl} target="_blank" rel="noreferrer">RTE äriprotsesside automatiseerimise ja andmevahetuse toetus</a>
              </div>
            </details>
          </div>
        </div>
      </section>

      <section class="white">
        <div class="section-inner narrow">
          <div class="plain-warning">
            <h2>Mida see näidis ei tähenda?</h2>
            <p>
              See ei ole EIS-i otsus ega lubadus, et toetus tuleb. See on omaniku tööriist:
              kas tasub edasi kontrollida või mitte. Lõpliku otsuse teeb EIS/RTK ametliku
              taotluse ja dokumentide põhjal.
            </p>
          </div>
        </div>
      </section>

      <section class="navy">
        <div class="section-inner contact">
          <div>
            <span class="kicker">Järgmine samm</span>
            <h2>Soovite sama kontrolli oma ettevõttele?</h2>
            <p>
              Saatke ettevõtte nimi ja registrikood. Kontrollime esmased tingimused ning ütleme,
              kas digiteekaardiga tasub edasi liikuda.
            </p>
            <div class="inline-actions">
              <a class="btn btn-primary" href="/#eelhindamine">Tee eelhindamine</a>
              <a class="btn btn-secondary" href="tel:+37258180435">Helista +372 5818 0435</a>
            </div>
          </div>
          <aside class="contact-card">
            <h3>Kontakt</h3>
            <p>Ettevõtluskeskus OÜ / 02Signal</p>
            <p><a href={emailHref}>info@02signal.ai</a></p>
            <p><a href="tel:+37258180435">+372 5818 0435</a></p>
          </aside>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <strong>Digiteekaart.ee</strong>
        <span>Ettevõtluskeskus OÜ · näidisaruanne · <a href="/privaatsus/">Privaatsus</a></span>
      </div>
    </footer>
  </body>
</html>
